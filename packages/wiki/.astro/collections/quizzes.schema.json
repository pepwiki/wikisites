{
  "$ref": "#/definitions/quizzes",
  "definitions": {
    "quizzes": {
      "type": "object",
      "properties": {
        "question": {
          "type": "string",
          "minLength": 1
        },
        "options": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 2
        },
        "correctIndex": {
          "type": "integer",
          "minimum": 0
        },
        "explanation": {
          "type": "string",
          "minLength": 1
        },
        "difficulty": {
          "type": "string",
          "enum": [
            "beginner",
            "intermediate",
            "advanced",
            "expert"
          ],
          "default": "intermediate"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "question",
        "options",
        "correctIndex",
        "explanation"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}