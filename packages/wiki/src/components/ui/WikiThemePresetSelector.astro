---
/**
 * WikiThemePresetSelector - Theme preset selector for wiki site.
 * Sits alongside Starlight's built-in theme toggle.
 * Usage: <WikiThemePresetSelector />
 */

interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div class={`relative ${className}`}>
  <button
    id="wiki-preset-toggle"
    type="button"
    class="flex items-center gap-1.5 px-2 py-1.5 rounded-md text-xs text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-[#0D9488] transition-colors"
    aria-label="Select theme preset"
    aria-haspopup="true"
    aria-expanded="false"
  >
    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"
      ></path>
    </svg>
    <span id="wiki-preset-label">Theme</span>
  </button>

  <div
    id="wiki-preset-menu"
    class="hidden absolute right-0 mt-1 w-40 rounded-lg shadow-lg bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 z-50"
    role="menu"
  >
    <div class="py-1">
      <button
        class="wiki-preset-option w-full text-left px-3 py-1.5 text-xs text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700"
        data-preset="light"
        role="menuitem"
      >
        <span class="inline-block w-2.5 h-2.5 rounded-full bg-white border border-slate-300 mr-1.5"
        ></span>
        Light
      </button>
      <button
        class="wiki-preset-option w-full text-left px-3 py-1.5 text-xs text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700"
        data-preset="dark"
        role="menuitem"
      >
        <span
          class="inline-block w-2.5 h-2.5 rounded-full bg-slate-900 border border-slate-600 mr-1.5"
        ></span>
        Dark
      </button>
      <button
        class="wiki-preset-option w-full text-left px-3 py-1.5 text-xs text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700"
        data-preset="high-contrast"
        role="menuitem"
      >
        <span class="inline-block w-2.5 h-2.5 rounded-full bg-black border border-white mr-1.5"
        ></span>
        High Contrast
      </button>
      <button
        class="wiki-preset-option w-full text-left px-3 py-1.5 text-xs text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700"
        data-preset="solarized"
        role="menuitem"
      >
        <span
          class="inline-block w-2.5 h-2.5 rounded-full bg-[#002b36] border border-[#2aa198] mr-1.5"
        ></span>
        Solarized
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var toggle = document.getElementById("wiki-preset-toggle");
    var menu = document.getElementById("wiki-preset-menu");
    var label = document.getElementById("wiki-preset-label");
    var options = document.querySelectorAll(".wiki-preset-option");

    var presetNames = { light: "Light", dark: "Dark", "high-contrast": "HC", solarized: "Solar" };
    var current = localStorage.getItem("wikisites:theme-preset") || "light";
    label.textContent = presetNames[current] || "Theme";

    toggle.addEventListener("click", function () {
      var isExpanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", !isExpanded);
      menu.classList.toggle("hidden");
    });

    options.forEach(function (opt) {
      opt.addEventListener("click", function () {
        var preset = opt.getAttribute("data-preset");
        localStorage.setItem("wikisites:theme-preset", preset);
        label.textContent = presetNames[preset] || "Theme";
        menu.classList.add("hidden");
        toggle.setAttribute("aria-expanded", "false");
        window.location.reload();
      });
    });

    document.addEventListener("click", function (e) {
      if (!toggle.contains(e.target) && !menu.contains(e.target)) {
        menu.classList.add("hidden");
        toggle.setAttribute("aria-expanded", "false");
      }
    });
  })();
</script>
