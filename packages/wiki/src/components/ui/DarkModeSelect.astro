---
/**
 * DarkModeSelect - A select dropdown with built-in dark mode support.
 * Usage: <DarkModeSelect options={[{value: "a", label: "A"}]} />
 */

interface Props {
  options: { value: string; label: string }[];
  class?: string;
  id?: string;
  name?: string;
}

const { options, class: className = "", id, name } = Astro.props;
---

<select
  id={id}
  name={name}
  class={`w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-2 text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-[#0D9488] focus:border-transparent transition-colors ${className}`}
>
  {options.map((opt) => <option value={opt.value}>{opt.label}</option>)}
</select>
