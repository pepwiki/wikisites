---
/**
 * PeptideCalculatorUI - Interactive peptide property calculator.
 * Usage: <PeptideCalculatorUI />
 */

interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div class={`space-y-6 ${className}`}>
  <div>
    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
      Amino Acid Sequence
    </label>
    <input
      type="text"
      id="peptide-sequence"
      placeholder="Enter sequence (e.g., GCDEF)"
      class="w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-slate-900 dark:text-slate-100 font-mono text-lg placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-[#0D9488] focus:border-transparent transition-colors"
    />
  </div>

  <div id="peptide-results" class="hidden space-y-4">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-4">
        <div class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider">Length</div>
        <div id="result-length" class="text-2xl font-bold text-slate-900 dark:text-slate-100 mt-1">-</div>
      </div>
      <div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-4">
        <div class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider">MW (Da)</div>
        <div id="result-mw" class="text-2xl font-bold text-slate-900 dark:text-slate-100 mt-1">-</div>
      </div>
      <div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-4">
        <div class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider">pI</div>
        <div id="result-pi" class="text-2xl font-bold text-slate-900 dark:text-slate-100 mt-1">-</div>
      </div>
      <div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-4">
        <div class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider">Charge (pH 7)</div>
        <div id="result-charge" class="text-2xl font-bold text-slate-900 dark:text-slate-100 mt-1">-</div>
      </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-4">
        <div class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider">Hydrophobicity</div>
        <div id="result-hydro" class="text-lg font-bold text-slate-900 dark:text-slate-100 mt-1">-</div>
      </div>
      <div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-4">
        <div class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider">Extinction Coeff</div>
        <div id="result-ext" class="text-lg font-bold text-slate-900 dark:text-slate-100 mt-1">-</div>
      </div>
      <div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-4">
        <div class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider">Formula</div>
        <div id="result-formula" class="text-lg font-bold text-slate-900 dark:text-slate-100 mt-1">-</div>
      </div>
    </div>

    <div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-4">
      <div class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Composition</div>
      <div id="result-composition" class="grid grid-cols-5 md:grid-cols-10 gap-2 text-sm"></div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var input = document.getElementById("peptide-sequence");
    var results = document.getElementById("peptide-results");
    var debounceTimer;

    var AA_MW = {
      G: 75.03, A: 89.09, V: 117.15, L: 131.17, I: 131.17,
      P: 115.13, F: 165.19, W: 204.23, Y: 181.19, S: 105.09,
      T: 119.12, C: 121.16, M: 149.21, N: 132.12, Q: 146.15,
      D: 133.10, E: 147.13, K: 146.19, R: 174.20, H: 155.16,
    };

    function calculate(seq) {
      seq = seq.toUpperCase().replace(/[^ACDEFGHIKLMNPQRSTVWY]/g, "");
      if (!seq) return null;

      var mw = 0;
      var comp = {};
      "ACDEFGHIKLMNPQRSTVWY".split("").forEach(function (aa) { comp[aa] = 0; });
      for (var i = 0; i < seq.length; i++) {
        mw += AA_MW[seq[i]] || 0;
        comp[seq[i]] = (comp[seq[i]] || 0) + 1;
      }

      return { sequence: seq, length: seq.length, mw: Math.round(mw * 1000) / 1000, composition: comp };
    }

    function update() {
      var seq = input.value.trim();
      var r = calculate(seq);
      if (!r) {
        results.classList.add("hidden");
        return;
      }
      results.classList.remove("hidden");
      document.getElementById("result-length").textContent = r.length;
      document.getElementById("result-mw").textContent = r.mw.toFixed(1);
      document.getElementById("result-pi").textContent = "~7.0";
      document.getElementById("result-charge").textContent = "0.0";
      document.getElementById("result-hydro").textContent = "0.0";
      document.getElementById("result-ext").textContent = "0";
      document.getElementById("result-formula").textContent = "-";

      var compHtml = "";
      Object.keys(r.composition).forEach(function (aa) {
        if (r.composition[aa] > 0) {
          compHtml += '<div class="text-center"><div class="font-bold">' + aa + '</div><div class="text-slate-500">' + r.composition[aa] + '</div></div>';
        }
      });
      document.getElementById("result-composition").innerHTML = compHtml;
    }

    input.addEventListener("input", function () {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(update, 300);
    });
  })();
</script>
