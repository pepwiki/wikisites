---
/**
 * DarkModeSkeleton - A skeleton loader with built-in dark mode support.
 * Usage: <DarkModeSkeleton lines={3} />
 */

interface Props {
  lines?: number;
  class?: string;
  width?: string;
}

const { lines = 3, class: className = "", width = "100%" } = Astro.props;
---

<div class={`animate-pulse ${className}`} role="status" aria-label="Loading">
  {
    Array.from({ length: lines }).map((_, i) => (
      <div
        class={`h-4 bg-slate-200 dark:bg-slate-700 rounded ${i < lines - 1 ? "mb-3" : ""}`}
        style={`width: ${i === lines - 1 ? "75%" : width}`}
      />
    ))
  }
  <span class="sr-only">Loading...</span>
</div>
