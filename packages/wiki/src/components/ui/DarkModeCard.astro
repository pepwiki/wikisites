---
/**
 * DarkModeCard - A card component with built-in dark mode support.
 * Usage: <DarkModeCard class="extra-classes">Content</DarkModeCard>
 */

interface Props {
  class?: string;
  variant?: "default" | "elevated" | "outlined";
}

const { class: className = "", variant = "default" } = Astro.props;

const variants = {
  default: "bg-white dark:bg-slate-900 border-slate-200 dark:border-slate-800",
  elevated:
    "bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700 shadow-lg dark:shadow-slate-950/50",
  outlined: "bg-transparent border-slate-200 dark:border-slate-700",
};
---

<div class={`rounded-xl border p-6 ${variants[variant]} ${className}`}>
  <slot />
</div>
