---
/**
 * DarkModeProgress - A progress bar with built-in dark mode support.
 * Usage: <DarkModeProgress value={75} max={100} />
 */

interface Props {
  value: number;
  max?: number;
  class?: string;
  color?: string;
}

const { value, max = 100, class: className = "", color = "bg-[#0f766e]" } = Astro.props;
const percentage = Math.min(100, Math.max(0, (value / max) * 100));
---

<div class={`w-full bg-slate-200 dark:bg-slate-700 rounded-full overflow-hidden ${className}`}>
  <div
    class={`${color} h-full rounded-full transition-all duration-300`}
    style={`width: ${percentage}%`}
    role="progressbar"
    aria-valuenow={value}
    aria-valuemin={0}
    aria-valuemax={max}
  >
  </div>
</div>
