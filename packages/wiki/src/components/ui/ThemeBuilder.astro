---
/**
 * ThemeBuilder - Custom theme builder component.
 * Allows users to create custom color schemes.
 * Usage: <ThemeBuilder />
 */

interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div class={`space-y-6 ${className}`}>
  <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100">Custom Theme Builder</h3>
  <p class="text-sm text-slate-600 dark:text-slate-400">Create your own color scheme.</p>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"
        >Background</label
      >
      <input
        type="color"
        id="theme-bg"
        value="#f8fafc"
        class="w-full h-10 rounded-lg cursor-pointer"
      />
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"
        >Surface</label
      >
      <input
        type="color"
        id="theme-surface"
        value="#ffffff"
        class="w-full h-10 rounded-lg cursor-pointer"
      />
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Text</label>
      <input
        type="color"
        id="theme-text"
        value="#1e293b"
        class="w-full h-10 rounded-lg cursor-pointer"
      />
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Accent</label
      >
      <input
        type="color"
        id="theme-accent"
        value="#0d9488"
        class="w-full h-10 rounded-lg cursor-pointer"
      />
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"
        >Muted Text</label
      >
      <input
        type="color"
        id="theme-muted"
        value="#64748b"
        class="w-full h-10 rounded-lg cursor-pointer"
      />
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Border</label
      >
      <input
        type="color"
        id="theme-border"
        value="#e2e8f0"
        class="w-full h-10 rounded-lg cursor-pointer"
      />
    </div>
  </div>

  <div class="flex gap-3">
    <button
      id="theme-apply"
      type="button"
      class="px-4 py-2 bg-[#0D9488] text-white rounded-lg hover:bg-[#0D9488]/90 transition-colors"
    >
      Apply Theme
    </button>
    <button
      id="theme-reset"
      type="button"
      class="px-4 py-2 bg-slate-200 dark:bg-slate-700 text-slate-700 dark:text-slate-300 rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors"
    >
      Reset
    </button>
    <button
      id="theme-export"
      type="button"
      class="px-4 py-2 bg-slate-200 dark:bg-slate-700 text-slate-700 dark:text-slate-300 rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors"
    >
      Export
    </button>
  </div>

  <div id="theme-preview" class="p-4 rounded-lg border border-slate-200 dark:border-slate-700">
    <h4 class="font-bold mb-2">Preview</h4>
    <p class="text-sm mb-2">This is how your theme will look.</p>
    <button class="px-3 py-1 text-sm rounded-lg bg-[var(--custom-accent)] text-white"
      >Accent Button</button
    >
  </div>
</div>

<script is:inline>
  (function () {
    var STORAGE_KEY = "wikisites:custom-theme";

    var fields = ["bg", "surface", "text", "accent", "muted", "border"];

    // Load saved theme
    var saved = localStorage.getItem(STORAGE_KEY);
    if (saved) {
      try {
        var theme = JSON.parse(saved);
        fields.forEach(function (f) {
          var input = document.getElementById("theme-" + f);
          if (input && theme[f]) input.value = theme[f];
        });
        applyTheme(theme);
      } catch (e) {}
    }

    // Apply button
    document.getElementById("theme-apply").addEventListener("click", function () {
      var theme = {};
      fields.forEach(function (f) {
        theme[f] = document.getElementById("theme-" + f).value;
      });
      localStorage.setItem(STORAGE_KEY, JSON.stringify(theme));
      applyTheme(theme);
    });

    // Reset button
    document.getElementById("theme-reset").addEventListener("click", function () {
      localStorage.removeItem(STORAGE_KEY);
      fields.forEach(function (f) {
        var input = document.getElementById("theme-" + f);
        if (input) input.value = input.defaultValue;
      });
      // Remove custom properties
      var root = document.documentElement;
      fields.forEach(function (f) {
        root.style.removeProperty("--custom-" + f);
      });
    });

    // Export button
    document.getElementById("theme-export").addEventListener("click", function () {
      var theme = {};
      fields.forEach(function (f) {
        theme[f] = document.getElementById("theme-" + f).value;
      });
      var blob = new Blob([JSON.stringify(theme, null, 2)], { type: "application/json" });
      var url = URL.createObjectURL(blob);
      var a = document.createElement("a");
      a.href = url;
      a.download = "wikisites-theme.json";
      a.click();
      URL.revokeObjectURL(url);
    });

    function applyTheme(theme) {
      var root = document.documentElement;
      fields.forEach(function (f) {
        if (theme[f]) {
          root.style.setProperty("--custom-" + f, theme[f]);
        }
      });
      // Update preview
      var preview = document.getElementById("theme-preview");
      if (preview) {
        preview.style.backgroundColor = theme.bg;
        preview.style.color = theme.text;
        preview.style.borderColor = theme.border;
      }
    }
  })();
</script>
