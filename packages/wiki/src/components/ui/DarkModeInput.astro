---
/**
 * DarkModeInput - An input component with built-in dark mode support.
 * Usage: <DarkModeInput placeholder="Search..." />
 */

interface Props {
  type?: string;
  placeholder?: string;
  class?: string;
  id?: string;
  name?: string;
}

const { type = "text", placeholder = "", class: className = "", id, name } = Astro.props;
---

<input
  type={type}
  placeholder={placeholder}
  id={id}
  name={name}
  class={`w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-2 text-slate-900 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-[#0D9488] focus:border-transparent transition-colors ${className}`}
/>
