---
import BaseLayout from "../layouts/BaseLayout.astro";
import QuizSession from "../components/QuizSession.tsx";
import { getCollection } from "astro:content";

const allQuizzes = await getCollection("quizzes");

const questions = allQuizzes
  .map((entry) => ({
    id: entry.id,
    question: entry.data.question,
    options: entry.data.options,
    correctIndex: entry.data.correctIndex,
    explanation: entry.data.explanation,
    difficulty: entry.data.difficulty,
    tags: entry.data.tags,
  }))
  .sort((a, b) => a.id.localeCompare(b.id));
---

<BaseLayout title="Quizzes">
  <h1 class="text-4xl font-extrabold mb-8 text-slate-900 dark:text-slate-100">Practice Quizzes</h1>
  <p class="text-slate-600 dark:text-slate-400 mb-8">
    Test your knowledge with interactive quizzes. Each answer is tracked by FSRS to optimize your
    learning schedule.
  </p>

  <QuizSession client:load questions={questions} title="All Quizzes" />
</BaseLayout>
