---
import BaseLayout from "../layouts/BaseLayout.astro";
import Quiz from "../components/Quiz.tsx";
---

<BaseLayout title="Quizzes">
  <h1 class="text-4xl font-extrabold mb-8 text-slate-900">Practice Quizzes</h1>
  <p class="text-slate-600 mb-8">
    Test your knowledge with interactive quizzes. Each answer is tracked by FSRS to optimize your learning schedule.
  </p>

  <div class="mb-12">
    <h2 class="text-2xl font-bold mb-6 text-slate-900">Amino Acid Basics</h2>
    <Quiz client:load question="Which amino acid has the smallest side chain?" options={["Glycine", "Alanine", "Valine", "Serine"]} correctIndex={0} explanation="Glycine has only a hydrogen atom as its side chain, making it the smallest and most flexible amino acid." cardId="quiz-aa-smallest" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="Which amino acid contains a thiol (-SH) group?" options={["Serine", "Cysteine", "Threonine", "Methionine"]} correctIndex={1} explanation="Cysteine contains a thiol group that can form disulfide bonds, crucial for protein folding and stability." cardId="quiz-aa-thiol" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is the one-letter code for Tryptophan?" options={["T", "W", "Y", "F"]} correctIndex={1} explanation="Tryptophan uses W as its one-letter code. The double ring structure reminded early biochemists of a 'double-u' shape." cardId="quiz-aa-tryptophan" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="Which amino acid is the start codon?" options={["Alanine", "Methionine", "Leucine", "Valine"]} correctIndex={1} explanation="Methionine (M) is encoded by the AUG start codon. In bacteria, formyl-methionine (fMet) is used instead." cardId="quiz-aa-start" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="Which amino acid has a cyclic side chain that bonds back to the nitrogen?" options={["Phenylalanine", "Tryptophan", "Proline", "Histidine"]} correctIndex={2} explanation="Proline's side chain bonds back to the backbone nitrogen, creating a rigid ring structure that introduces kinks in protein chains." cardId="quiz-aa-proline" site="wiki" deckId="quiz-all" />
  </div>

  <div class="mb-12">
    <h2 class="text-2xl font-bold mb-6 text-slate-900">Peptide Bond Chemistry</h2>
    <Quiz client:load question="What type of bond connects amino acids in a peptide?" options={["Ester bond", "Amide bond", "Thioester bond", "Ether bond"]} correctIndex={1} explanation="A peptide bond is an amide bond formed between the carboxyl group of one amino acid and the amino group of another, releasing water." cardId="quiz-pb-type" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What percentage of peptide bonds adopt the trans configuration?" options={["50%", "90%", "99.6%", "100%"]} correctIndex={2} explanation="Approximately 99.6% of peptide bonds are trans. The exceptions are primarily X-Pro bonds where cis is more common." cardId="quiz-pb-trans" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What gives the peptide bond its partial double bond character?" options={["Hydrogen bonding", "Resonance", "Hydrophobic interaction", "Van der Waals forces"]} correctIndex={1} explanation="Resonance between the carbonyl oxygen and the amide nitrogen creates partial double bond character, restricting rotation around the C-N bond." cardId="quiz-pb-resonance" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is the approximate length of a C-N peptide bond?" options={["1.49 Angstrom", "1.32 Angstrom", "1.21 Angstrom", "1.54 Angstrom"]} correctIndex={1} explanation="The C-N peptide bond is 1.32 Angstrom, shorter than a typical C-N single bond (1.49A) due to partial double bond character." cardId="quiz-pb-length" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="How much energy is required to hydrolyze a peptide bond?" options={["1-4 kJ/mol", "8-16 kJ/mol", "50-100 kJ/mol", "200+ kJ/mol"]} correctIndex={1} explanation="Peptide bond hydrolysis requires approximately 8-16 kJ/mol. The bond is thermodynamically favorable to break but kinetically slow without enzymatic catalysis." cardId="quiz-pb-energy" site="wiki" deckId="quiz-all" />
  </div>

  <div class="mb-12">
    <h2 class="text-2xl font-bold mb-6 text-slate-900">Protein Structure</h2>
    <Quiz client:load question="Which protein structure level describes the 3D folding of a single polypeptide chain?" options={["Primary", "Secondary", "Tertiary", "Quaternary"]} correctIndex={2} explanation="Tertiary structure is the overall three-dimensional shape of a single polypeptide chain, stabilized by hydrophobic interactions, disulfide bonds, and ionic bonds." cardId="quiz-ps-tertiary" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What stabilizes the alpha-helix structure?" options={["Disulfide bonds", "Hydrogen bonds between backbone atoms", "Ionic bonds", "Hydrophobic interactions"]} correctIndex={1} explanation="The alpha-helix is stabilized by hydrogen bonds between the C=O of residue i and the N-H of residue i+4, creating a regular helical pattern." cardId="quiz-ps-alpha" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is the quaternary structure?" options={["Single polypeptide folding", "Secondary structure elements", "Multi-subunit assembly", "Amino acid sequence"]} correctIndex={2} explanation="Quaternary structure describes how multiple polypeptide chains (subunits) assemble into a functional protein complex." cardId="quiz-ps-quaternary" site="wiki" deckId="quiz-all" />
  </div>

  <div class="mb-12">
    <h2 class="text-2xl font-bold mb-6 text-slate-900">Pharmacology</h2>
    <Quiz client:load question="What is the incretin effect?" options={["Oral glucose produces more insulin than IV glucose", "IV glucose produces more insulin than oral glucose", "Insulin inhibits glucagon", "Glucagon stimulates insulin"]} correctIndex={0} explanation="The incretin effect means oral glucose produces more insulin than the same amount given intravenously, mediated by GLP-1 and GIP from the gut." cardId="quiz-pharm-incretin" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What does PEGylation do to a peptide drug?" options={["Increases receptor binding", "Extends half-life by increasing hydrodynamic radius", "Reduces immunogenicity", "All of the above"]} correctIndex={3} explanation="PEGylation increases hydrodynamic radius (reducing renal clearance), reduces immunogenicity by shielding epitopes, and can indirectly improve binding by increasing circulation time." cardId="quiz-pharm-peg" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is the difference between Ki and Kd?" options={["Ki is for agonists, Kd for antagonists", "Ki measures inhibition, Kd measures dissociation", "They are the same thing", "Ki is always larger than Kd"]} correctIndex={1} explanation="Ki is the inhibition constant for antagonist binding. Kd is the dissociation constant for any ligand-receptor binding. Lower values indicate higher affinity." cardId="quiz-pharm-kikd" site="wiki" deckId="quiz-all" />
  </div>

  <div class="mb-12">
    <h2 class="text-2xl font-bold mb-6 text-slate-900">Advanced Topics</h2>
    <Quiz client:load question="What is a cyclic peptide?" options={["A peptide with only 2 amino acids", "A peptide with a covalent bond connecting termini or side chains", "A peptide that forms a ring in solution", "A peptide with disulfide bonds only"]} correctIndex={1} explanation="Cyclic peptides have a covalent bond (amide, disulfide, or other) connecting the N-terminus to C-terminus or side chains, creating a macrocyclic structure." cardId="quiz-adv-cyclic" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is a stapled peptide?" options={["A peptide with disulfide crosslinks", "A peptide with a hydrocarbon crosslock between side chains", "A peptide attached to a surface", "A peptide that has been purified by HPLC"]} correctIndex={1} explanation="Stapled peptides have a hydrocarbon crosslink between non-adjacent side chains (typically i and i+3 or i and i+7), locking the peptide into an alpha-helical conformation." cardId="quiz-adv-stapled" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is N-methylation used for in peptide drugs?" options={["Increases water solubility", "Reduces H-bond donor capacity to improve oral bioavailability", "Adds a fluorescent label", "Increases molecular weight only"]} correctIndex={1} explanation="N-methylation of backbone amides reduces H-bond donor capacity and desolvation penalty, which can dramatically improve oral bioavailability. Cyclosporine is a natural example." cardId="quiz-adv-nmeth" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is a peptidomimetic?" options={["A modified natural peptide", "A non-peptide molecule mimicking peptide biological activity", "A peptide with all D-amino acids", "A peptide degraded by proteases"]} correctIndex={1} explanation="Peptidomimetics are non-peptide molecules designed to mimic the biological activity of peptides while offering improved stability and bioavailability." cardId="quiz-adv-mimetic" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is the key advantage of peptide self-assembly?" options={["It makes peptides cheaper to synthesize", "It creates ordered nanostructures without external scaffolding", "It prevents peptide degradation", "It increases receptor binding affinity"]} correctIndex={1} explanation="Peptide self-assembly spontaneously creates ordered structures (nanofibers, hydrogels, micelles) driven by non-covalent interactions, enabling applications in tissue engineering and drug delivery." cardId="quiz-adv-assembly" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is racemization in peptide chemistry?" options={["Formation of peptide bonds", "Conversion of L-amino acids to D-form", "Breaking of disulfide bonds", "Phosphorylation of serine residues"]} correctIndex={1} explanation="Racemization is the non-enzymatic conversion of L-amino acids to D-form, accelerated by high temperature and alkaline pH. It is a critical stability concern in peptide drug storage." cardId="quiz-adv-racem" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is a GPCR?" options={["Guanine nucleotide-binding Protein Coupled Receptor", "G-Protein Coupled Receptor", "Glycoprotein Cell Receptor", "General Peptide Recognition Complex"]} correctIndex={1} explanation="GPCR stands for G-Protein Coupled Receptor. These seven-transmembrane domain receptors are the largest family of drug targets, coupling to G-proteins for signal transduction." cardId="quiz-adv-gpcr" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is the residence time concept in pharmacology?" options={["How long a drug stays in the body", "How long a drug remains bound to its receptor", "The shelf life of a drug formulation", "The time to reach peak plasma concentration"]} correctIndex={1} explanation="Residence time is the reciprocal of the dissociation rate constant (koff). It represents how long a drug remains bound to its receptor, which often correlates better with efficacy than binding affinity alone." cardId="quiz-adv-residence" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is a peptide-drug conjugate?" options={["A peptide mixed with a drug in solution", "A peptide linked to a cytotoxic payload via a cleavable linker", "A peptide that is also a drug", "A drug that contains a peptide sequence"]} correctIndex={1} explanation="Peptide-drug conjugates link a targeting peptide to a cytotoxic payload through a cleavable linker. The peptide guides the drug to specific cells, where the linker is cleaved to release the payload." cardId="quiz-adv-pdc" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is biased signaling in GPCR pharmacology?" options={["The receptor only binds one ligand", "The receptor activates one signaling pathway preferentially", "The receptor is only expressed in one tissue", "The ligand has no therapeutic effect"]} correctIndex={1} explanation="Biased signaling occurs when a ligand preferentially activates one downstream signaling pathway (e.g., G-protein vs beta-arrestin) over another at the same receptor, enabling more selective therapeutics." cardId="quiz-adv-biased" site="wiki" deckId="quiz-all" />
  </div>

  <div class="mb-12">
    <h2 class="text-2xl font-bold mb-6 text-slate-900">Cutting Edge</h2>
    <Quiz client:load question="What is a conotoxin?" options={["A bacterial toxin", "A venom peptide from cone snails that targets ion channels", "A synthetic peptide", "A plant defense peptide"]} correctIndex={1} explanation="Conotoxins are venom peptides from cone snails that target ion channels with high specificity. Ziconotide, a conotoxin drug, is used for severe chronic pain." cardId="quiz-ce-conotoxin" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is phage display used for?" options={["Sequencing viral DNA", "Screening peptide libraries by displaying peptides on bacteriophage surfaces", "Amplifying peptide signals", "Synthesizing peptides on solid support"]} correctIndex={1} explanation="Phage display is a technique where peptides are displayed on bacteriophage surfaces, allowing selection of high-affinity binders from large libraries. It is widely used in drug discovery." cardId="quiz-ce-phage" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is a cell-penetrating peptide?" options={["A peptide that kills cells", "A short peptide that crosses cell membranes to deliver cargo intracellularly", "A peptide that prevents cell division", "A peptide that identifies cell types"]} correctIndex={1} explanation="Cell-penetrating peptides (CPPs) are short peptides (5-30 aa) that can cross cell membranes, either alone or with cargo. Examples include TAT and penetratin." cardId="quiz-ce-cpp" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is PROTAC technology?" options={["Protein Replacement Therapy", "Proteolysis Targeting Chimera for induced protein degradation", "Peptide Receptor Optical Targeting", "Proline-Rich Tumor-Associated Antigen Capture"]} correctIndex={1} explanation="PROTACs are bifunctional molecules that link a target protein to an E3 ubiquitin ligase, inducing proteasomal degradation of the target. They work catalytically." cardId="quiz-ce-protac" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is a depsipeptide?" options={["A peptide with only D-amino acids", "A peptide containing ester bonds in addition to amide bonds", "A peptide that degrades peptides", "A peptide that binds DNA"]} correctIndex={1} explanation="Depsipeptides contain both amide and ester bonds. They are found in natural products and often have enhanced metabolic stability compared to pure peptides." cardId="quiz-ce-depsi" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is mirror-image phage display?" options={["Displaying peptides on mirror surfaces", "Screening D-peptide libraries using D-phage for protease-resistant binders", "Displaying both L and D peptides simultaneously", "A visualization technique for peptide structures"]} correctIndex={1} explanation="Mirror-image phage display uses D-phage to screen D-peptide libraries, producing protease-resistant D-peptide binders that are enantiomeric to natural L-peptides." cardId="quiz-ce-mirror" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is SNAC?" options={["A sodium salt for peptide preservation", "An absorption enhancer for oral semaglutide that protects peptide from gastric degradation", "A synthetic nucleic acid carrier", "A surfactant for peptide formulation"]} correctIndex={1} explanation="SNAC (Sodium N-[8-(2-hydroxybenzoyl)]amino caprylate) is an absorption enhancer that enables oral semaglutide by protecting the peptide from gastric degradation and facilitating absorption." cardId="quiz-ce-snac" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is a peptide dendrimer?" options={["A linear peptide chain", "A branched peptide architecture with a central core for multivalent binding", "A peptide that forms dendrites", "A peptide that degrades dendrimers"]} correctIndex={1} explanation="Peptide dendrimers are branched peptide architectures with a central core. They provide multivalent binding, enhanced avidity, and are used in vaccines and gene delivery." cardId="quiz-ce-dendrimer" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is a macrocycle in drug design?" options={["A circular piece of paper", "A ring structure with 12+ atoms providing conformational constraint", "A type of mass spectrometer", "A method for peptide purification"]} correctIndex={1} explanation="Macrocycles are ring structures with 12 or more atoms. They provide conformational constraint that can enhance target binding, but achieving cell permeability remains a challenge." cardId="quiz-ce-macrocycle" site="wiki" deckId="quiz-all" />
    <Quiz client:load question="What is SNIPPs?" options={["Selective Nucleophilic Isotope-labeled Peptides for quantification", "A type of peptide synthesis method", "A membrane protein purification technique", "A database of peptide sequences"]} correctIndex={0} explanation="SNIPPs (Selective Nucleophilic Isotope-labeled Peptides) are used for highly sensitive and selective quantification of peptides in biological matrices." cardId="quiz-ce-snipps" site="wiki" deckId="quiz-all" />
  </div>
</BaseLayout>
