---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Offline">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <h1 class="text-4xl font-bold text-slate-900 mb-4">You are offline</h1>
    <p class="text-lg text-slate-600 mb-8 max-w-md">
      It looks like your connection has been lost. Please check your network and try again.
    </p>
    <a
      href="/"
      class="inline-block bg-[#0D9488] text-white px-6 py-3 rounded-lg font-semibold hover:bg-teal-700 transition-colors"
    >
      Return home
    </a>
  </div>
</BaseLayout>
