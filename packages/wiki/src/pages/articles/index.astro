---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const articles = await getCollection("articles");
const sorted = articles.sort((a, b) => a.id.localeCompare(b.id));
---

<BaseLayout title="Articles" description="In-depth articles on peptide biology, chemistry, and pharmacology.">
  <h1 class="text-4xl font-extrabold mb-8 text-slate-900 dark:text-slate-100">Articles</h1>
  <p class="text-slate-600 dark:text-slate-400 mb-8">
    Explore our collection of {sorted.length} articles covering peptide biology, chemistry, pharmacology, and more.
  </p>
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {sorted.map((article) => (
      <a
        href={`/articles/${article.id}/`}
        class="block p-4 rounded-lg border border-slate-200 dark:border-slate-700 hover:border-[#0D9488] hover:shadow-md transition-all"
      >
        <h2 class="font-semibold text-slate-900 dark:text-slate-100">{article.data.title}</h2>
        {article.data.description && (
          <p class="text-sm text-slate-600 dark:text-slate-400 mt-1 line-clamp-2">{article.data.description}</p>
        )}
      </a>
    ))}
  </div>
</BaseLayout>
