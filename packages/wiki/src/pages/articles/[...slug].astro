---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReadingProgress from "../../components/ReadingProgress";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const siteUrl = "https://wikipept.com";
const canonicalUrl = `${siteUrl}/articles/${article.id}`;
const pubDateStr = article.data.pubDate.toISOString().split("T")[0];
const modDateStr = article.data.updatedDate
  ? article.data.updatedDate.toISOString().split("T")[0]
  : pubDateStr;

const scholarlyArticleJsonLd = {
  "@context": "https://schema.org",
  "@type": "ScholarlyArticle",
  headline: article.data.title,
  description: article.data.description,
  author: { "@type": "Organization", name: article.data.author },
  datePublished: pubDateStr,
  dateModified: modDateStr,
  publisher: {
    "@type": "Organization",
    name: "Wikipept",
    logo: { "@type": "ImageObject", url: `${siteUrl}/og-default.svg` },
  },
  mainEntityOfPage: canonicalUrl,
  image: `${siteUrl}/og-default.svg`,
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: article.data.category, item: `${siteUrl}/articles/` },
    { "@type": "ListItem", position: 3, name: article.data.title },
  ],
};

// Extract headings for Table of Contents
const headingRegex = /^#{2,3}\s+(.+)$/gm;
const headings = [];
let match;
while ((match = headingRegex.exec(article.body)) !== null) {
  const level = match[0].startsWith("### ") ? 3 : 2;
  const text = match[1].trim();
  const id = text
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");
  headings.push({ level, text, id });
}
---

<BaseLayout title={article.data.title} description={article.data.description}>
  <Fragment slot="head">
    <meta property="article:published_time" content={article.data.pubDate.toISOString()} />
    <meta property="article:author" content={article.data.author} />
    <meta property="og:type" content="article" />
    {article.data.tags.length > 0 && article.data.tags.map((tag: string) => (
      <meta property="article:tag" content={tag} />
    ))}
    <script is:inline type="application/ld+json" set:html={JSON.stringify(scholarlyArticleJsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>
  <ReadingProgress client:load />
  <article class="max-w-3xl">
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-bold bg-[#0D9488] text-white px-3 py-1 rounded-full uppercase">
          {article.data.category}
        </span>
        <span
          class="text-xs font-bold bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-400 px-3 py-1 rounded-full uppercase"
        >
          {article.data.difficulty}
        </span>
      </div>
      <h1 class="text-4xl font-extrabold text-slate-900 dark:text-slate-100 mb-4">
        {article.data.title}
      </h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 mb-4">{article.data.description}</p>
      <div class="flex items-center gap-4 text-sm text-slate-500 dark:text-slate-400">
        <span>By {article.data.author}</span>
        <time datetime={article.data.pubDate.toISOString()}>
          {
            article.data.pubDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </time>
        <span class="text-slate-400 dark:text-slate-500">|</span>
        <span>{Math.ceil(article.body.split(/\s+/).length / 200)} min read</span>
        {
          article.data.updatedDate && (
            <>
              <span class="text-slate-400 dark:text-slate-500">|</span>
              <span>
                Updated{" "}
                {article.data.updatedDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </span>
            </>
          )
        }
      </div>
      {
        article.data.tags.length > 0 && (
          <div class="flex gap-2 mt-4">
            {article.data.tags.map((tag) => (
              <span class="text-xs bg-slate-100 dark:bg-slate-700 text-slate-500 dark:text-slate-400 px-2 py-1 rounded">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </header>

    {
      headings.length > 0 && (
        <nav class="mb-8 p-4 bg-slate-50 dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700">
          <h2 class="text-sm font-semibold text-slate-900 dark:text-slate-100 mb-3">
            Table of Contents
          </h2>
          <ul class="space-y-1">
            {headings.map((h) => (
              <li class={h.level === 3 ? "ml-4" : ""}>
                <a
                  href={`#${h.id}`}
                  class="text-sm text-slate-600 dark:text-slate-400 hover:text-[#0D9488] transition-colors"
                >
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }

    <div class="prose prose-slate max-w-none">
      <Content />
    </div>

    {
      article.data.relatedArticles.length > 0 && (
        <nav class="mt-8 pt-8 border-t border-slate-200 dark:border-slate-700">
          <h3 class="font-semibold text-slate-900 dark:text-slate-100 mb-3">Related Articles</h3>
          <div class="flex gap-3 flex-wrap">
            {article.data.relatedArticles.map((slug) => (
              <a
                href={`/articles/${slug}`}
                class="text-sm text-[#0D9488] hover:underline border border-[#0D9488] px-3 py-1 rounded-full"
              >
                {slug}
              </a>
            ))}
          </div>
        </nav>
      )
    }
  </article>
</BaseLayout>
