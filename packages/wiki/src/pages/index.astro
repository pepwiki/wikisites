---
import BaseLayout from "../layouts/BaseLayout.astro";
import StreakWidget from "../components/StreakWidget.tsx";
---

<BaseLayout title="Home">
  <section class="relative py-16 text-center overflow-hidden">
    <!-- Amoebic blob decorations -->
    <div class="amoebic-blob w-96 h-96 -top-20 -left-20 opacity-40" aria-hidden="true"></div>
    <div class="amoebic-blob w-64 h-64 -bottom-10 -right-10 opacity-30" aria-hidden="true"></div>

    <h1 class="relative z-10 text-5xl font-extrabold mb-6 text-[#0D9488]">
      Learn <span class="text-[#F97316]">Oligopeptides</span>
    </h1>
    <p class="relative z-10 text-xl text-slate-600 max-w-2xl mx-auto mb-8">
      Interactive, community-driven platform for learning oligopeptide biology. Quizzes, flashcards,
      spaced repetition, and collaborative annotations.
    </p>
    <div class="relative z-10 flex gap-4 justify-center">
      <a
        href="/learn"
        class="px-6 py-3 bg-[#0D9488] text-white rounded-full font-medium hover:bg-[#0D9488]/90 transition-all hover:shadow-lg hover:shadow-teal-500/25 active:scale-95"
      >
        Start Learning
      </a>
      <a
        href="/quizzes"
        class="px-6 py-3 border-2 border-[#F97316] text-[#F97316] rounded-full font-medium hover:bg-[#F97316] hover:text-white transition-all hover:shadow-lg hover:shadow-orange-500/25 active:scale-95"
      >
        Take a Quiz
      </a>
    </div>
  </section>

  <section class="grid grid-cols-1 md:grid-cols-3 gap-8 py-8 relative z-10">
    <div class="spatial-card p-6">
      <h3 class="text-lg font-bold mb-3 text-slate-900">Continue Learning</h3>
      <p class="text-sm text-slate-600 mb-4">Pick up where you left off.</p>
      <div class="flex flex-col gap-2">
        <a href="/review" class="flex items-center gap-2 px-4 py-2.5 bg-[#0D9488]/10 text-[#0D9488] rounded-xl font-medium text-sm hover:bg-[#0D9488]/20 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
          Flashcard Review
        </a>
        <a href="/quizzes" class="flex items-center gap-2 px-4 py-2.5 bg-[#F97316]/10 text-[#F97316] rounded-xl font-medium text-sm hover:bg-[#F97316]/20 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
          Take a Quiz
        </a>
        <a href="/flashcards" class="flex items-center gap-2 px-4 py-2.5 bg-slate-100 text-slate-700 rounded-xl font-medium text-sm hover:bg-slate-200 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
          Browse Flashcards
        </a>
      </div>
    </div>
    <StreakWidget client:load />
  </section>

  <section class="grid grid-cols-1 md:grid-cols-3 gap-8 py-12 relative z-10">
    <div class="spatial-card p-6">
      <div class="w-12 h-12 bg-[#0D9488]/10 rounded-xl flex items-center justify-center mb-4" aria-hidden="true">
        <svg class="w-6 h-6 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
      </div>
      <h3 class="text-lg font-bold mb-2 text-slate-900">Interactive Tutorials</h3>
      <p class="text-slate-600 text-sm">
        Progressive lessons from beginner to expert. Visual diagrams, mnemonics, and real-world
        examples.
      </p>
    </div>
    <div class="spatial-card p-6">
      <div class="w-12 h-12 bg-[#F97316]/10 rounded-xl flex items-center justify-center mb-4" aria-hidden="true">
        <svg class="w-6 h-6 text-[#F97316]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
      </div>
      <h3 class="text-lg font-bold mb-2 text-slate-900">Spaced Repetition</h3>
      <p class="text-slate-600 text-sm">
        FSRS-powered flashcards that adapt to your learning pace. Optimized for long-term retention
        of amino acid sequences.
      </p>
    </div>
    <div class="spatial-card p-6">
      <div class="w-12 h-12 bg-[#0D9488]/10 rounded-xl flex items-center justify-center mb-4" aria-hidden="true">
        <svg class="w-6 h-6 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
      </div>
      <h3 class="text-lg font-bold mb-2 text-slate-900">Community Annotations</h3>
      <p class="text-slate-600 text-sm">
        Add notes, clarifications, and study tips to any article. Collaborative knowledge building
        with quality moderation.
      </p>
    </div>
  </section>

  <section class="py-12 border-t border-slate-200 relative z-10">
    <h2 class="text-3xl font-bold mb-8 text-slate-900">Popular Study Sets</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <a href="/learn/amino-acids" class="spatial-card block p-5">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-xs font-bold bg-[#0D9488] text-white px-2 py-1 rounded-full"
            >BEGINNER</span
          >
        </div>
        <h4 class="font-bold text-slate-900">20 Standard Amino Acids</h4>
        <p class="text-sm text-slate-500 mt-1">
          Learn all 20 amino acids with properties, structures, and mnemonics
        </p>
        <div class="flex items-center gap-4 mt-3 text-xs text-slate-400">
          <span>12 lessons</span>
          <span>48 flashcards</span>
          <span>3 quizzes</span>
        </div>
      </a>
      <a href="/learn/peptide-bonds" class="spatial-card block p-5">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-xs font-bold bg-[#F97316] text-white px-2 py-1 rounded-full"
            >INTERMEDIATE</span
          >
        </div>
        <h4 class="font-bold text-slate-900">Peptide Bond Chemistry</h4>
        <p class="text-sm text-slate-500 mt-1">
          Formation, hydrolysis, resonance, and stereochemistry
        </p>
        <div class="flex items-center gap-4 mt-3 text-xs text-slate-400">
          <span>8 lessons</span>
          <span>32 flashcards</span>
          <span>2 quizzes</span>
        </div>
      </a>
      <a href="/learn/pharmacology" class="spatial-card block p-5">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-xs font-bold bg-[#0D9488] text-white px-2 py-1 rounded-full"
            >BEGINNER</span
          >
        </div>
        <h4 class="font-bold text-slate-900">Therapeutic Peptides</h4>
        <p class="text-sm text-slate-500 mt-1">
          Overview of FDA-approved peptide drugs and their mechanisms
        </p>
        <div class="flex items-center gap-4 mt-3 text-xs text-slate-400">
          <span>10 lessons</span>
          <span>40 flashcards</span>
          <span>4 quizzes</span>
        </div>
      </a>
    </div>
  </section>

  <section class="py-12 spatial-card mt-8 relative z-10">
    <div class="text-center">
      <h2 class="text-2xl font-bold mb-4 text-slate-900">Track Your Progress</h2>
      <p class="text-slate-600 mb-6 max-w-lg mx-auto">
        Your progress is saved locally on this device. No account required. Start learning and your
        flashcard reviews and quiz scores will be tracked automatically.
      </p>
      <div class="flex gap-4 justify-center">
        <div class="text-center px-6">
          <div class="text-3xl font-bold text-[#0D9488]">30</div>
          <div class="text-sm text-slate-500">Articles</div>
        </div>
        <div class="text-center px-6 border-x border-slate-200">
          <div class="text-3xl font-bold text-[#F97316]">29</div>
          <div class="text-sm text-slate-500">Flashcards</div>
        </div>
        <div class="text-center px-6">
          <div class="text-3xl font-bold text-[#0D9488]">23</div>
          <div class="text-sm text-slate-500">Quiz Questions</div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
