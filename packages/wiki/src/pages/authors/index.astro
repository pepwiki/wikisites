---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Authors" description="Meet the Wikipept team of contributors and editors.">
  <h1 class="text-4xl font-extrabold mb-8 text-slate-900 dark:text-slate-100">Authors</h1>
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    <a
      href="/authors/wikipept-team/"
      class="block p-6 rounded-lg border border-slate-200 dark:border-slate-700 hover:border-[#0D9488] hover:shadow-md transition-all"
    >
      <h2 class="font-semibold text-lg text-slate-900 dark:text-slate-100">Wikipept Team</h2>
      <p class="text-sm text-slate-600 dark:text-slate-400 mt-2">Community-driven content contributors</p>
    </a>
  </div>
</BaseLayout>
