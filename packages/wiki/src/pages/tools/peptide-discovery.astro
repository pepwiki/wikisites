    let sortAscending = true;

    function renderTable(data) {
      const tbody = document.getElementById("peptide-tbody");
      tbody.innerHTML = data.map(p => `
        <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600">
          <td class="px-6 py-4 font-medium text-gray-900 dark:text-white">${p.name}</td>
          <td class="px-6 py-4">${p.class}</td>
          <td class="px-6 py-4">${p.halfLife}</td>
          <td class="px-6 py-4">${p.mw.toLocaleString()}</td>
          <td class="px-6 py-4">${p.charge > 0 ? "+" : ""}${p.charge}</td>
          <td class="px-6 py-4">${p.route}</td>
          <td class="px-6 py-4">${p.indication}</td>
          <td class="px-6 py-4"><span class="${p.approved ? 'text-green-600 dark:text-green-400' : 'text-yellow-600 dark:text-yellow-400'}">${p.approved ? 'Approved' : 'Research'}</span></td>
        </tr>
      `).join("");
      document.getElementById("results-count").textContent = `Showing ${data.length} peptide(s)`;
    }

    function filterData() {
      const classVal = document.getElementById("class-filter").value;
      const indicationVal = document.getElementById("indication-filter").value;
      const approvedVal = document.getElementById("approved-filter").value;
      const hlMin = parseFloat(document.getElementById("half-life-min").value) || 0;
      const hlMax = parseFloat(document.getElementById("half-life-max").value) || 999;
      const chargeVal = document.getElementById("charge-filter").value;
      const searchVal = document.getElementById("search-input").value.toLowerCase();

      const filtered = peptideData.filter(p => {
        if (classVal && p.class !== classVal) return false;
        if (indicationVal && !p.indication.toLowerCase().includes(indicationVal.toLowerCase())) return false;
        if (approvedVal !== "" && p.approved.toString() !== approvedVal) return false;
        if (p.halfLifeHours < hlMin || p.halfLifeHours > hlMax) return false;
        if (chargeVal === "positive" && p.charge <= 0) return false;
        if (chargeVal === "negative" && p.charge >= 0) return false;
        if (chargeVal === "neutral" && p.charge !== 0) return false;
        if (searchVal && !p.name.toLowerCase().includes(searchVal)) return false;
        return true;
      });

      renderTable(filtered);
    }

    document.getElementById("class-filter").addEventListener("change", filterData);
    document.getElementById("indication-filter").addEventListener("change", filterData);
    document.getElementById("approved-filter").addEventListener("change", filterData);
    document.getElementById("half-life-min").addEventListener("input", filterData);
    document.getElementById("half-life-max").addEventListener("input", filterData);
    document.getElementById("charge-filter").addEventListener("change", filterData);
    document.getElementById("search-input").addEventListener("input", filterData);

    document.getElementById("reset-btn").addEventListener("click", () => {
      document.getElementById("class-filter").value = "";
      document.getElementById("indication-filter").value = "";
      document.getElementById("approved-filter").value = "";
      document.getElementById("half-life-min").value = "";
      document.getElementById("half-life-max").value = "";
      document.getElementById("charge-filter").value = "";
      document.getElementById("search-input").value = "";
      filterData();
    });

    document.getElementById("sort-btn").addEventListener("click", () => {
      peptideData.sort((a, b) => sortAscending ? a.halfLifeHours - b.halfLifeHours : b.halfLifeHours - a.halfLifeHours);
      sortAscending = !sortAscending;
      filterData();
    });

    renderTable(peptideData);
  </script>
