---
import BaseLayout from "../../layouts/BaseLayout.astro";

const siteUrl = "https://wikipept.com";

const howToJsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "How to Use the Peptide Discovery Tool",
  step: [
    {
      "@type": "HowToStep",
      name: "Select Desired Properties",
      text: "Choose one or more peptide properties (half-life, charge, hydrophobicity) from the filter options.",
    },
    {
      "@type": "HowToStep",
      name: "Filter by Classification",
      text: "Narrow results by peptide class (GLP-1 RA, GHS, repair peptide, etc.) or indication.",
    },
    {
      "@type": "HowToStep",
      name: "Set Parameter Ranges",
      text: "Define minimum and maximum values for half-life, molecular weight, or other physicochemical parameters.",
    },
    {
      "@type": "HowToStep",
      name: "Review Matching Peptides",
      text: "View the filtered peptide database with properties, mechanisms, and clinical data.",
    },
  ],
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How does the peptide discovery tool work?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "The tool searches a database of 50+ peptides filtered by physicochemical properties (half-life, charge, hydrophobicity, molecular weight), peptide class, and clinical indication. You select desired properties and the tool returns peptides matching all criteria.",
      },
    },
    {
      "@type": "Question",
      name: "What peptide classes are included?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "The database includes GLP-1 receptor agonists, GIP agonists, dual GIP/GLP-1 agonists, growth hormone secretagogues, GH analogues, repair peptides (BPC-157, TB-500, GHK-Cu), melanocortin analogues, oxytocin/vasopressin analogues, thymic peptides, insulin analogues, amylin analogues, and natriuretic peptides.",
      },
    },
    {
      "@type": "Question",
      name: "Can I search by half-life range?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. The tool allows you to filter peptides by half-life range (minutes, hours, days, or weeks). This helps identify peptides suitable for different dosing frequencies — from ultra-rapid (minutes) to ultra-long-acting (weekly).",
      },
    },
    {
      "@type": "Question",
      name: "Is this tool for clinical decision-making?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "No. This tool is for educational and research purposes only. It provides pharmacological data about peptides but does not constitute medical advice. Always consult qualified healthcare providers for clinical decisions.",
      },
    },
    {
      "@type": "Question",
      name: "How current is the peptide database?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "The database is updated quarterly with data from published literature, FDA approvals, and clinical trial registries. Last updated July 2026.",
      },
    },
  ],
};

const peptideDatabase = [
