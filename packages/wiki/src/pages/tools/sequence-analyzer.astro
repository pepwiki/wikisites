  <script is:inline>
    document.addEventListener("DOMContentLoaded", function () {
      const aaData = {
        G: { mw: 75.03, kd: -0.4, type: "nonpolar", color: "orange" },
        A: { mw: 89.09, kd: 1.8, type: "nonpolar", color: "green" },
        V: { mw: 117.15, kd: 4.2, type: "nonpolar", color: "green" },
        L: { mw: 131.17, kd: 3.8, type: "nonpolar", color: "green" },
        I: { mw: 131.17, kd: 4.5, type: "nonpolar", color: "green" },
        P: { mw: 115.13, kd: -1.6, type: "nonpolar", color: "orange" },
        F: { mw: 165.19, kd: 2.8, type: "nonpolar", color: "green" },
        W: { mw: 204.23, kd: -0.9, type: "nonpolar", color: "green" },
        M: { mw: 149.21, kd: 1.9, type: "nonpolar", color: "green" },
        S: { mw: 105.09, kd: -0.8, type: "polar", color: "yellow" },
        T: { mw: 119.12, kd: -0.7, type: "polar", color: "yellow" },
        C: { mw: 121.16, kd: 2.5, type: "polar", color: "orange", pka: 8.18 },
        Y: { mw: 181.19, kd: -1.3, type: "polar", color: "yellow", pka: 10.07 },
        H: { mw: 155.16, kd: -3.2, type: "basic", color: "blue", pka: 6.0 },
        D: { mw: 133.1, kd: -3.5, type: "acidic", color: "red", pka: 3.65 },
        E: { mw: 147.13, kd: -3.5, type: "acidic", color: "red", pka: 4.25 },
        N: { mw: 132.12, kd: -3.5, type: "polar", color: "yellow" },
        Q: { mw: 146.15, kd: -3.5, type: "polar", color: "yellow" },
        K: { mw: 146.19, kd: -3.9, type: "basic", color: "blue", pka: 10.53 },
        R: { mw: 174.2, kd: -4.5, type: "basic", color: "blue", pka: 12.48 },
      };

      const nTermPka = 9.69;
      const cTermPka = 2.34;

      function calculateCharge(residues, pH) {
        let charge = 0;
        charge += 1 / (1 + Math.pow(10, pH - nTermPka));
        charge -= 1 / (1 + Math.pow(10, cTermPka - pH));
        for (const r of residues) {
          const aa = aaData[r];
          if (!aa) continue;
          if (aa.type === "acidic" && aa.pka) {
            charge -= 1 / (1 + Math.pow(10, aa.pka - pH));
          } else if (aa.type === "basic" && aa.pka) {
            charge += 1 / (1 + Math.pow(10, pH - aa.pka));
          }
        }
        return charge;
      }

      function calculatePI(residues) {
        const ionizable = [];
        ionizable.push({ group: "N-term", pka: nTermPka, type: "base" });
        ionizable.push({ group: "C-term", pka: cTermPka, type: "acid" });
        for (const r of residues) {
          const aa = aaData[r];
          if (aa && aa.pka) {
            ionizable.push({
              group: r,
              pka: aa.pka,
              type: aa.type === "acidic" ? "acid" : "base",
            });
          }
        }
        ionizable.sort((a, b) => a.pka - b.pka);

        let bestPH = 7.0;
        let minCharge = Infinity;
        for (let ph = 0; ph <= 14; ph += 0.01) {
          const ch = Math.abs(calculateCharge(residues, ph));
          if (ch < minCharge) {
            minCharge = ch;
            bestPH = ph;
          }
        }
        return bestPH.toFixed(2);
      }

      function analyzeStability(residues) {
        const issues = [];
        const suggestions = [];
        const n = residues.length;
        
        // N-terminal analysis
        const nTerm = residues[0];
        if (nTerm === "Q" || nTerm === "D") {
          issues.push("N-terminal " + nTerm + " promotes cyclization (pyroglutamate formation)");
          suggestions.push("Consider N-terminal acetylation or D-amino acid substitution");
        } else if (nTerm === "P" || nTerm === "A" || nTerm === "V") {
          issues.push("N-terminal " + nTerm + " is stabilizing");
        } else if (nTerm === "R" || nTerm === "K") {
          issues.push("N-terminal " + nTerm + " is susceptible to aminopeptidases");
          suggestions.push("Consider N-terminal acetylation");
        }

        // Check for DPP-4 cleavage motifs
        for (let i = 0; i < residues.length - 1; i++) {
          if ((residues[i] === "A" || residues[i] === "G" || residues[i] === "S" || residues[i] === "T") && 
              (residues[i + 1] === "P" || residues[i + 1] === "A")) {
            issues.push("Potential DPP-4 cleavage site at position " + (i + 1) + "-" + (i + 2));
            suggestions.push("Consider D-amino acid substitution at position " + (i + 2));
          }
        }

        // Check for trypsin cleavage sites
        for (let i = 0; i < residues.length; i++) {
          if (residues[i] === "K" || residues[i] === "R") {
            if (i < residues.length - 1 && residues[i + 1] !== "P") {
              issues.push("Trypsin cleavage site at position " + (i + 1));
              suggestions.push("Consider D-amino acid substitution at position " + (i + 1));
            }
          }
        }

        // Length analysis
        if (n < 10) {
          issues.push("Short peptide (" + n + " aa) - rapid renal clearance");
          suggestions.push("Consider PEGylation or albumin binding");
        } else if (n > 50) {
          issues.push("Long peptide (" + n + " aa) - may require formulation optimization");
          suggestions.push("Consider cyclization or lipidation");
        }

        // Hydrophobicity analysis
        let kdSum = 0;
        for (const r of residues) {
          const aa = aaData[r];
          if (aa) kdSum += aa.kd;
        }
        const kd = kdSum / n;
        if (kd > 2.0) {
          issues.push("Highly hydrophobic sequence - may aggregate");
          suggestions.push("Consider adding charged residues or PEGylation");
        } else if (kd < -2.0) {
          issues.push("Highly hydrophilic sequence - may have poor membrane permeability");
          suggestions.push("Consider cyclization or lipidation");
        }

        // Charge analysis
        const charge = calculateCharge(residues, 7.4);
        if (Math.abs(charge) > 3) {
          issues.push("High net charge (" + charge.toFixed(2) + ") - may affect stability");
          suggestions.push("Consider charge balancing mutations");
        }

        return { issues, suggestions };
      }

      function renderVisualSequence(residues) {
        const container = document.getElementById("visualSequence");
        container.innerHTML = "";
        
        for (let i = 0; i < residues.length; i++) {
          const r = residues[i];
          const aa = aaData[r];
          const span = document.createElement("span");
          span.className = "inline-flex items-center justify-center w-8 h-8 rounded font-bold text-white text-sm";
          span.textContent = r;
          span.title = "Position " + (i + 1) + ": " + r;
          
          switch (aa.color) {
            case "green":
              span.classList.add("bg-green-500");
              break;
            case "blue":
              span.classList.add("bg-blue-500");
              break;
            case "red":
              span.classList.add("bg-red-500");
              break;
            case "yellow":
              span.classList.add("bg-yellow-500", "text-slate-900");
              break;
            case "orange":
              span.classList.add("bg-orange-500");
              break;
          }
          
          container.appendChild(span);
        }
      }

      function analyze() {
        const seq = document.getElementById("sequence").value.toUpperCase().replace(/[^A-Z]/g, "");
        const pH = parseFloat(document.getElementById("ph").value) || 7.4;
        const disulfide = parseInt(document.getElementById("disulfide").value) || 0;

        if (!seq) {
          alert("Please enter a valid peptide sequence.");
          return;
        }

        const residues = seq.split("");
        const n = residues.length;
        let mw = 0;
        let kdSum = 0;
        let nTrp = 0, nTyr = 0, nCys = 0;
        const comp = {};

        for (const r of residues) {
          const aa = aaData[r];
          if (!aa) {
            alert("Invalid amino acid: " + r);
            return;
          }
          mw += aa.mw;
          kdSum += aa.kd;
          if (r === "W") nTrp++;
          if (r === "Y") nTyr++;
          if (r === "C") nCys++;
          comp[r] = (comp[r] || 0) + 1;
        }

        mw -= (n - 1) * 18.015;
        mw -= disulfide * 2.016;
        const kd = kdSum / n;
        const pI = calculatePI(residues);
        const charge = calculateCharge(residues, pH);
        const extinction = nTrp * 5500 + nTyr * 1490 + nCys * 125;

        let halfLife;
        if (n <= 5) halfLife = 2 + Math.random() * 3;
        else if (n <= 10) halfLife = 5 + Math.random() * 10;
        else if (n <= 20) halfLife = 10 + Math.random() * 20;
        else halfLife = 15 + Math.random() * 30;

        const first = residues[0];
        if (first === "Q" || first === "D") halfLife *= 0.5;
        else if (first === "P" || first === "A" || first === "V") halfLife *= 1.5;

        document.getElementById("mw").textContent = mw.toFixed(2);
        document.getElementById("pi").textContent = pI;
        document.getElementById("charge").textContent = charge >= 0 ? "+" + charge.toFixed(2) : charge.toFixed(2);
        document.getElementById("hydro").textContent = kd.toFixed(2);
        document.getElementById("extinction").textContent = extinction.toLocaleString();
        document.getElementById("halflife").textContent = halfLife.toFixed(1);
        document.getElementById("molarMass").textContent = mw.toFixed(2);
        document.getElementById("phDisplay").textContent = pH;

        // Visual sequence
        renderVisualSequence(residues);

        // Stability analysis
        const { issues, suggestions } = analyzeStability(residues);
        
        const stabilityDiv = document.getElementById("stabilityAssessment");
        if (issues.length === 0) {
          stabilityDiv.innerHTML = '<div class="text-green-600 dark:text-green-400">✓ No major stability concerns identified</div>';
        } else {
          stabilityDiv.innerHTML = issues.map(issue => '<div class="flex items-start gap-2"><span class="text-yellow-500">⚠</span><span>' + issue + '</span></div>').join("");
        }

        const suggestionsDiv = document.getElementById("modificationSuggestions");
        if (suggestions.length === 0) {
          suggestionsDiv.innerHTML = '<div class="text-green-600 dark:text-green-400">✓ No modifications suggested</div>';
        } else {
          suggestionsDiv.innerHTML = suggestions.map(s => '<div class="flex items-start gap-2"><span class="text-blue-500">💡</span><span>' + s + '</span></div>').join("");
        }

        // Composition table
        let compHtml = '<table class="w-full text-sm"><thead><tr class="border-b border-slate-200 dark:border-slate-700"><th class="text-left py-1 px-2">AA</th><th class="text-right py-1 px-2">Count</th><th class="text-right py-1 px-2">%</th></tr></thead><tbody>';
        const sorted = Object.entries(comp).sort((a, b) => b[1] - a[1]);
        for (const [aa, count] of sorted) {
          compHtml += `<tr class="border-b border-slate-100 dark:border-slate-800"><td class="py-1 px-2 font-mono font-bold">${aa}</td><td class="py-1 px-2 text-right">${count}</td><td class="py-1 px-2 text-right">${((count / n) * 100).toFixed(1)}%</td></tr>`;
        }
        compHtml += "</tbody></table>";
        document.getElementById("compTable").innerHTML = compHtml;

        document.getElementById("results").classList.remove("hidden");
      }

      document.getElementById("analyzeBtn").addEventListener("click", analyze);
    });
  </script>
</BaseLayout>