  <script is:inline type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": "Peptide Property Calculator",
  "description": "Calculate molecular weight, pI, net charge, hydrophobicity, extinction coefficient, and half-life for any peptide sequence",
  "url": "https://wikipept.com/tools/peptide-property-calculator/",
  "medicalAudience": {
    "@type": "MedicalAudience",
    "audienceType": "Researcher"
  },
  "lastReviewed": "2026-07-21"
}
  </script>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", function () {
      const aaData = {
        G: { mw: 75.03, kd: -0.4, type: "nonpolar" },
        A: { mw: 89.09, kd: 1.8, type: "nonpolar" },
        V: { mw: 117.15, kd: 4.2, type: "nonpolar" },
        L: { mw: 131.17, kd: 3.8, type: "nonpolar" },
        I: { mw: 131.17, kd: 4.5, type: "nonpolar" },
        P: { mw: 115.13, kd: -1.6, type: "nonpolar" },
        F: { mw: 165.19, kd: 2.8, type: "nonpolar" },
        W: { mw: 204.23, kd: -0.9, type: "nonpolar" },
        M: { mw: 149.21, kd: 1.9, type: "nonpolar" },
        S: { mw: 105.09, kd: -0.8, type: "polar" },
        T: { mw: 119.12, kd: -0.7, type: "polar" },
        C: { mw: 121.16, kd: 2.5, type: "polar", pka: 8.18 },
        Y: { mw: 181.19, kd: -1.3, type: "polar", pka: 10.07 },
        H: { mw: 155.16, kd: -3.2, type: "basic", pka: 6.0 },
        D: { mw: 133.1, kd: -3.5, type: "acidic", pka: 3.65 },
        E: { mw: 147.13, kd: -3.5, type: "acidic", pka: 4.25 },
        N: { mw: 132.12, kd: -3.5, type: "polar" },
        Q: { mw: 146.15, kd: -3.5, type: "polar" },
        K: { mw: 146.19, kd: -3.9, type: "basic", pka: 10.53 },
        R: { mw: 174.2, kd: -4.5, type: "basic", pka: 12.48 },
      };

      const nTermPka = 9.69;
      const cTermPka = 2.34;

      function calculateCharge(residues, pH) {
        let charge = 0;
        charge += 1 / (1 + Math.pow(10, pH - nTermPka));
        charge -= 1 / (1 + Math.pow(10, cTermPka - pH));
        for (const r of residues) {
          const aa = aaData[r];
          if (!aa) continue;
          if (aa.type === "acidic" && aa.pka) {
            charge -= 1 / (1 + Math.pow(10, aa.pka - pH));
          } else if (aa.type === "basic" && aa.pka) {
            charge += 1 / (1 + Math.pow(10, pH - aa.pka));
          }
        }
        return charge;
      }

      function calculatePI(residues) {
        const ionizable = [];
        ionizable.push({ group: "N-term", pka: nTermPka, type: "base" });
        ionizable.push({ group: "C-term", pka: cTermPka, type: "acid" });
        for (const r of residues) {
          const aa = aaData[r];
          if (aa && aa.pka) {
            ionizable.push({
              group: r,
              pka: aa.pka,
              type: aa.type === "acidic" ? "acid" : "base",
            });
          }
        }
        ionizable.sort((a, b) => a.pka - b.pka);

        let bestPH = 7.0;
        let minCharge = Infinity;
        for (let ph = 0; ph <= 14; ph += 0.01) {
          const ch = Math.abs(calculateCharge(residues, ph));
          if (ch < minCharge) {
            minCharge = ch;
            bestPH = ph;
          }
        }
        return bestPH.toFixed(2);
      }

      function calculate() {
        const seq = document.getElementById("sequence").value.toUpperCase().replace(/[^A-Z]/g, "");
        const pH = parseFloat(document.getElementById("ph").value) || 7.4;
        const disulfide = parseInt(document.getElementById("disulfide").value) || 0;

        if (!seq) {
          alert("Please enter a valid peptide sequence.");
          return;
        }

        const residues = seq.split("");
        const n = residues.length;
        let mw = 0;
        let kdSum = 0;
        let nTrp = 0, nTyr = 0, nCys = 0;
        const comp = {};

        for (const r of residues) {
          const aa = aaData[r];
          if (!aa) {
            alert("Invalid amino acid: " + r);
            return;
          }
          mw += aa.mw;
          kdSum += aa.kd;
          if (r === "W") nTrp++;
          if (r === "Y") nTyr++;
          if (r === "C") nCys++;
          comp[r] = (comp[r] || 0) + 1;
        }

        mw -= (n - 1) * 18.015;
        mw -= disulfide * 2.016;
        const kd = kdSum / n;
        const pI = calculatePI(residues);
        const charge = calculateCharge(residues, pH);
        const extinction = nTrp * 5500 + nTyr * 1490 + nCys * 125;

        let halfLife;
        if (n <= 5) halfLife = 2 + Math.random() * 3;
        else if (n <= 10) halfLife = 5 + Math.random() * 10;
        else if (n <= 20) halfLife = 10 + Math.random() * 20;
        else halfLife = 15 + Math.random() * 30;

        const first = residues[0];
        if (first === "Q" || first === "D") halfLife *= 0.5;
        else if (first === "P" || first === "A" || first === "V") halfLife *= 1.5;

        document.getElementById("mw").textContent = mw.toFixed(2);
        document.getElementById("pi").textContent = pI;
        document.getElementById("charge").textContent = charge >= 0 ? "+" + charge.toFixed(2) : charge.toFixed(2);
        document.getElementById("hydro").textContent = kd.toFixed(2);
        document.getElementById("extinction").textContent = extinction.toLocaleString();
        document.getElementById("halflife").textContent = halfLife.toFixed(1);
        document.getElementById("phDisplay").textContent = pH;
        document.getElementById("results").classList.remove("hidden");

        let compHtml = '<table class="w-full text-sm"><thead><tr class="border-b border-slate-200 dark:border-slate-700"><th class="text-left py-1 px-2">AA</th><th class="text-right py-1 px-2">Count</th><th class="text-right py-1 px-2">%</th></tr></thead><tbody>';
        const sorted = Object.entries(comp).sort((a, b) => b[1] - a[1]);
        for (const [aa, count] of sorted) {
          compHtml += `<tr class="border-b border-slate-100 dark:border-slate-800"><td class="py-1 px-2 font-mono font-bold">${aa}</td><td class="py-1 px-2 text-right">${count}</td><td class="py-1 px-2 text-right">${((count / n) * 100).toFixed(1)}%</td></tr>`;
        }
        compHtml += "</tbody></table>";
        document.getElementById("compTable").innerHTML = compHtml;
      }

      document.getElementById("calculateBtn").addEventListener("click", calculate);
    });
  </script>
</BaseLayout>
