---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Peptide Database" description="Searchable database of therapeutic peptides with properties, indications, and clinical data.">
  <h1 class="text-4xl font-extrabold mb-8 text-slate-900 dark:text-slate-100">Peptide Database</h1>
  <p class="text-slate-600 dark:text-slate-400 mb-8">
    Browse our comprehensive database of therapeutic peptides with molecular properties, clinical data, and regulatory status.
  </p>
  <a
    href="/database/peptides/"
    class="inline-block px-6 py-3 bg-[#0D9488] text-white rounded-lg hover:bg-[#0f766e] transition-colors font-medium"
  >
    Open Database
  </a>
</BaseLayout>
