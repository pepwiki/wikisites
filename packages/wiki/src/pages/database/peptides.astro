---

<BaseLayout
  title="Peptide Database | Wikipept"
  description="Searchable database of 100+ therapeutic peptides — molecular properties, pharmacokinetics, clinical status, and comparison links. Free research tool."
>
  <article class="max-w-6xl mx-auto">
    <header class="mb-8">
      <h1 class="text-4xl font-extrabold text-slate-900 dark:text-slate-100 mb-4">
        Peptide Database
      </h1>
      <p class="text-lg text-slate-600 dark:text-slate-400">
        Searchable database of therapeutic and research peptides with molecular properties, pharmacokinetics, and clinical status. Filter by class, half-life, indication, or approval status.
      </p>
    </header>

    <section class="mb-8 p-6 bg-slate-50 dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700">
      <div class="grid gap-4 md:grid-cols-4">
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Search</label>
          <input type="text" id="searchInput" placeholder="Search by name, sequence, or indication..." class="w-full rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-900 px-3 py-2 text-slate-900 dark:text-slate-100" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Class</label>
          <select id="classFilter" class="w-full rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-900 px-3 py-2 text-slate-900 dark:text-slate-100">
            <option value="">All Classes</option>
            <option value="Hormone">Hormone</option>
            <option value="GLP-1 RA">GLP-1 RA</option>
            <option value="GIP/GLP-1">GIP/GLP-1</option>
            <option value="Neuropeptide">Neuropeptide</option>
            <option value="Somatostatin">Somatostatin</option>
            <option value="GnRH Agonist">GnRH Agonist</option>
            <option value="GnRH Antagonist">GnRH Antagonist</option>
            <option value="MC4R Agonist">MC4R Agonist</option>
            <option value="MC1R Agonist">MC1R Agonist</option>
            <option value="Thymosin">Thymosin</option>
            <option value="mAb">mAb</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Status</label>
          <select id="statusFilter" class="w-full rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-900 px-3 py-2 text-slate-900 dark:text-slate-100">
            <option value="">All Statuses</option>
            <option value="Approved">Approved</option>
            <option value="Phase III">Phase III</option>
            <option value="Research">Research</option>
            <option value="Discontinued">Discontinued</option>
          </select>
        </div>
      </div>
      <div class="grid gap-4 md:grid-cols-3 mt-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Half-Life</label>
          <select id="halfLifeFilter" class="w-full rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-900 px-3 py-2 text-slate-900 dark:text-slate-100">
            <option value="">All Half-Lives</option>
            <option value="short"><1 hour</option>
            <option value="medium">1-24 hours</option>
            <option value="long">1-7 days</option>
            <option value="extended">>7 days</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Indication</label>
          <select id="indicationFilter" class="w-full rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-900 px-3 py-2 text-slate-900 dark:text-slate-100">
            <option value="">All Indications</option>
            <option value="Diabetes">Diabetes</option>
            <option value="Obesity">Obesity</option>
            <option value="Acromegaly">Acromegaly</option>
            <option value="Prostate Cancer">Prostate Cancer</option>
            <option value="Migraine">Migraine</option>
            <option value="Pain">Pain</option>
            <option value="Osteoporosis">Osteoporosis</option>
            <option value="IVF">IVF</option>
          </select>
        </div>
        <div class="flex items-end">
          <button id="exportBtn" class="px-4 py-2 bg-slate-200 dark:bg-slate-700 text-slate-700 dark:text-slate-300 rounded-lg font-medium hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors">
            Export CSV
          </button>
        </div>
      </div>
    </section>

    <section class="mb-8">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100">
          <span id="resultCount">{peptides.length}</span> peptides found
        </h2>
        <div class="text-sm text-slate-500">
          Click column headers to sort
        </div>
      </div>
      <div class="overflow-x-auto rounded-xl border border-slate-200 dark:border-slate-700">
        <table class="w-full text-sm" id="peptideTable">
          <thead>
            <tr class="bg-slate-50 dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700">
              <th class="text-left py-3 px-4 cursor-pointer hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-900 dark:text-slate-100 font-semibold" data-sort="name">Name ↕</th>
              <th class="text-left py-3 px-4 cursor-pointer hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-900 dark:text-slate-100 font-semibold" data-sort="seq">Sequence</th>
              <th class="text-left py-3 px-4 cursor-pointer hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-900 dark:text-slate-100 font-semibold" data-sort="mw">MW (Da) ↕</th>
              <th class="text-left py-3 px-4 cursor-pointer hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-900 dark:text-slate-100 font-semibold" data-sort="hl">Half-Life ↕</th>
              <th class="text-left py-3 px-4 text-slate-900 dark:text-slate-100 font-semibold">Class</th>
              <th class="text-left py-3 px-4 text-slate-900 dark:text-slate-100 font-semibold">Indication</th>
              <th class="text-left py-3 px-4 text-slate-900 dark:text-slate-100 font-semibold">Status</th>
            </tr>
          </thead>
          <tbody id="tableBody" class="divide-y divide-slate-100 dark:divide-slate-800">
          </tbody>
        </table>
      </div>
    </section>

    <section class="mb-12 grid gap-4 md:grid-cols-3">
      <div class="p-4 bg-slate-50 dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700">
        <div class="text-3xl font-bold text-[#0D9488]">{peptides.filter(p => p.status === 'Approved').length}</div>
        <div class="text-sm text-slate-600 dark:text-slate-400">FDA/EMA Approved</div>
      </div>
      <div class="p-4 bg-slate-50 dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700">
        <div class="text-3xl font-bold text-[#0D9488]">{peptides.filter(p => p.status === 'Phase III').length}</div>
        <div class="text-sm text-slate-600 dark:text-slate-400">Phase III Clinical</div>
      </div>
      <div class="p-4 bg-slate-50 dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700">
        <div class="text-3xl font-bold text-[#0D9488]">{peptides.length}</div>
        <div class="text-sm text-slate-600 dark:text-slate-400">Total Peptides</div>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-100 mb-4">Frequently Asked Questions</h2>
      <div class="space-y-6">
        <div>
          <h3 class="font-semibold text-slate-900 dark:text-slate-100 mb-2">How many peptides are in the database?</h3>
          <p class="text-slate-600 dark:text-slate-400">
            The Wikipept peptide database contains over {peptides.length} therapeutic and research peptides with complete molecular data, pharmacokinetic properties, and clinical status information.
          </p>
        </div>
        <div>
          <h3 class="font-semibold text-slate-900 dark:text-slate-100 mb-2">How is peptide half-life data determined?</h3>
          <p class="text-slate-600 dark:text-slate-400">
            Half-life data are derived from published pharmacokinetic studies, regulatory filings (FDA, EMA), and peer-reviewed literature. Values represent typical plasma half-lives after subcutaneous or intravenous administration in humans.
          </p>
        </div>
      </div>
    </section>

    <section class="p-6 bg-[#0D9488]/5 border border-[#0D9488]/20 rounded-xl">
      <h3 class="font-semibold text-[#0f766e] mb-2">Related Resources</h3>
      <ul class="text-sm text-slate-600 dark:text-slate-400 space-y-1">
        <li><a href="/reference/approved-peptides" class="text-[#0D9488] hover:underline">Reference: FDA-Approved Peptides</a></li>
        <li><a href="/reference/physicochemical-properties" class="text-[#0D9488] hover:underline">Reference: Physicochemical Properties</a></li>
        <li><a href="/reference/receptor-binding" class="text-[#0D9488] hover:underline">Reference: Receptor Binding Affinities</a></li>
        <li><a href="/tools/sequence-designer" class="text-[#0D9488] hover:underline">Tool: Sequence Designer</a></li>
      </ul>
    </section>
  </article>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(howToJsonLd)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(datasetJsonLd)} />

  <script is:inline>
    const peptideData = {JSON.stringify(peptides)};

    let filteredData = [...peptideData];
    let sortColumn = 'name';
    let sortDirection = 'asc';

    function parseHalfLife(hl) {
      if (hl.includes('min')) return parseFloat(hl) / 60;
      if (hl.includes('hrs') || hl.includes('hr')) return parseFloat(hl);
      if (hl.includes('days') || hl.includes('day')) return parseFloat(hl) * 24;
      if (hl.includes('weeks') || hl.includes('week')) return parseFloat(hl) * 168;
      return 0;
    }

    function matchesHalfLifeFilter(hl, filter) {
      const hours = parseHalfLife(hl);
      if (filter === 'short') return hours < 1;
      if (filter === 'medium') return hours >= 1 && hours <= 24;
      if (filter === 'long') return hours > 24 && hours <= 168;
      if (filter === 'extended') return hours > 168;
      return true;
    }

    function renderTable() {
      const tbody = document.getElementById('tableBody');
      const countEl = document.getElementById('resultCount');
      
      filteredData.sort((a, b) => {
        let valA, valB;
        if (sortColumn === 'mw') { valA = a.mw; valB = b.mw; }
        else if (sortColumn === 'hl') { valA = parseHalfLife(a.hl); valB = parseHalfLife(b.hl); }
        else { valA = a[sortColumn]; valB = b[sortColumn]; }
        if (valA < valB) return sortDirection === 'asc' ? -1 : 1;
        if (valA > valB) return sortDirection === 'asc' ? 1 : -1;
        return 0;
      });

      countEl.textContent = filteredData.length;
      tbody.innerHTML = filteredData.map(p => `
        <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50">
          <td class="py-3 px-4 font-medium text-slate-900 dark:text-slate-100">${p.name}</td>
          <td class="py-3 px-4 font-mono text-xs text-slate-600 dark:text-slate-400 max-w-[200px] truncate">${p.seq}</td>
          <td class="py-3 px-4 text-slate-600 dark:text-slate-400">${p.mw.toLocaleString()}</td>
          <td class="py-3 px-4 text-slate-600 dark:text-slate-400">${p.hl}</td>
          <td class="py-3 px-4"><span class="px-2 py-1 rounded-full text-xs bg-[#0D9488]/10 text-[#0D9488]">${p.class}</span></td>
          <td class="py-3 px-4 text-slate-600 dark:text-slate-400">${p.indication}</td>
          <td class="py-3 px-4"><span class="px-2 py-1 rounded-full text-xs ${p.status === 'Approved' ? 'bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300' : p.status === 'Phase III' ? 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900 dark:text-yellow-300' : 'bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300'}">${p.status}</span></td>
        </tr>
      `).join('');
    }

    function filterData() {
      const search = document.getElementById('searchInput').value.toLowerCase();
      const classFilter = document.getElementById('classFilter').value;
      const statusFilter = document.getElementById('statusFilter').value;
      const hlFilter = document.getElementById('halfLifeFilter').value;
      const indicationFilter = document.getElementById('indicationFilter').value;

      filteredData = peptideData.filter(p => {
        const matchesSearch = !search || p.name.toLowerCase().includes(search) || p.seq.toLowerCase().includes(search) || p.indication.toLowerCase().includes(search);
        const matchesClass = !classFilter || p.class === classFilter;
        const matchesStatus = !statusFilter || p.status === statusFilter;
        const matchesHL = matchesHalfLifeFilter(p.hl, hlFilter);
        const matchesIndication = !indicationFilter || p.indication.includes(indicationFilter);
        return matchesSearch && matchesClass && matchesStatus && matchesHL && matchesIndication;
      });

      renderTable();
    }

    function exportCSV() {
      const headers = ['Name', 'Sequence', 'MW (Da)', 'Half-Life', 'Class', 'Indication', 'Status'];
      const rows = filteredData.map(p => [p.name, p.seq, p.mw, p.hl, p.class, p.indication, p.status].join(','));
      const csv = [headers.join(','), ...rows].join('\n');
      const blob = new Blob([csv], { type: 'text/csv' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'peptide-database.csv';
      a.click();
      URL.revokeObjectURL(url);
    }

    document.getElementById('searchInput').addEventListener('input', filterData);
    document.getElementById('classFilter').addEventListener('change', filterData);
    document.getElementById('statusFilter').addEventListener('change', filterData);
    document.getElementById('halfLifeFilter').addEventListener('change', filterData);
    document.getElementById('indicationFilter').addEventListener('change', filterData);
    document.getElementById('exportBtn').addEventListener('click', exportCSV);

    document.querySelectorAll('th[data-sort]').forEach(th => {
      th.addEventListener('click', () => {
        const col = th.dataset.sort;
        if (sortColumn === col) { sortDirection = sortDirection === 'asc' ? 'desc' : 'asc'; }
        else { sortColumn = col; sortDirection = 'asc'; }
        renderTable();
      });
    });

    renderTable();
  </script>
</BaseLayout>
