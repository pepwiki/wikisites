---
import { getCollection } from "astro:content";

const site = "https://wikipept.com";

const staticPages = [
  { path: "/", priority: "1.0", changefreq: "weekly" },
  { path: "/learn", priority: "0.9", changefreq: "weekly" },
  { path: "/review", priority: "0.8", changefreq: "weekly" },
  { path: "/quizzes", priority: "0.8", changefreq: "weekly" },
  { path: "/flashcards", priority: "0.8", changefreq: "weekly" },
  { path: "/community", priority: "0.7", changefreq: "weekly" },
  { path: "/reference/glossary", priority: "0.7", changefreq: "monthly" },
  { path: "/privacy", priority: "0.3", changefreq: "yearly" },
  { path: "/daily", priority: "0.6", changefreq: "daily" },
  { path: "/database/peptides", priority: "0.7", changefreq: "monthly" },
];

const toolPages = [
  { path: "/tools/molecular-weight-calculator", priority: "0.7", changefreq: "monthly" },
  { path: "/tools/reconstitution-calculator", priority: "0.7", changefreq: "monthly" },
  { path: "/tools/peptide-property-calculator", priority: "0.7", changefreq: "monthly" },
  { path: "/tools/stability-predictor", priority: "0.7", changefreq: "monthly" },
  { path: "/tools/sequence-designer", priority: "0.7", changefreq: "monthly" },
  { path: "/tools/interaction-checker", priority: "0.7", changefreq: "monthly" },
  { path: "/tools/sequence-analyzer", priority: "0.7", changefreq: "monthly" },
];

const authorPages = [
  { path: "/authors/wikipept-team", priority: "0.5", changefreq: "monthly" },
];

const topics = [
  { slug: "peptide-synthesis", priority: "0.8", changefreq: "weekly" },
  { slug: "amino-acids", priority: "0.8", changefreq: "weekly" },
  { slug: "pharmacology", priority: "0.8", changefreq: "weekly" },
  { slug: "drug-discovery", priority: "0.8", changefreq: "weekly" },
  { slug: "receptors", priority: "0.8", changefreq: "weekly" },
  { slug: "peptide-structure", priority: "0.8", changefreq: "weekly" },
];

const topicPages = topics.map((topic) => ({
  path: `/topics/${topic.slug}`,
  priority: topic.priority,
  changefreq: topic.changefreq,
}));

const docs = await getCollection("docs");
const learnPages = docs
  .filter((doc) => doc.id.startsWith("learn/"))
  .map((doc) => ({
    path: `/learn/${doc.id.replace("learn/", "")}`,
    priority: "0.8",
    changefreq: "monthly",
    lastmod: doc.data.lastUpdated
      ? new Date(doc.data.lastUpdated).toISOString().split("T")[0]
      : undefined,
  }));

const referencePages = docs
  .filter((doc) => doc.id.startsWith("reference/"))
  .map((doc) => ({
    path: `/reference/${doc.id.replace("reference/", "")}`,
    priority: "0.7",
    changefreq: "monthly",
    lastmod: doc.data.lastUpdated
      ? new Date(doc.data.lastUpdated).toISOString().split("T")[0]
      : undefined,
  }));

const articles = await getCollection("articles");
const articlePages = articles.map((article) => ({
  path: `/articles/${article.id}`,
  priority: "0.8",
  changefreq: "weekly",
  lastmod: article.data.pubDate.toISOString().split("T")[0],
}));

const quizzes = await getCollection("quizzes");
const quizTags = [...new Set(quizzes.flatMap((q) => q.data.tags ?? []))];
const quizTagPages = quizTags.map((tag) => ({
  path: `/quizzes/${tag}`,
  priority: "0.6",
  changefreq: "weekly",
}));

const flashcards = await getCollection("flashcards");
const flashcardTags = [...new Set(flashcards.flatMap((f) => f.data.tags ?? []))];
const flashcardTagPages = flashcardTags.map((tag) => ({
  path: `/flashcards/${tag}`,
  priority: "0.6",
  changefreq: "weekly",
}));

const allPages = [
  ...staticPages,
  ...toolPages,
  ...authorPages,
  ...topicPages,
  ...learnPages,
  ...referencePages,
  ...articlePages,
  ...quizTagPages,
  ...flashcardTagPages,
];

return new Response(
  `<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
${allPages
  .map(
    (page) => `  <url>
    <loc>${site}${page.path}</loc>
    <changefreq>${page.changefreq}</changefreq>
    <priority>${page.priority}</priority>
${page.lastmod ? `    <lastmod>${page.lastmod}</lastmod>` : ""}
  </url>`,
  )
  .join("\n")}
</urlset>`,
  {
    headers: {
      "Content-Type": "application/xml; charset=utf-8",
    },
  },
);
---