---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import FlashcardDeck from "../components/FlashcardDeck.tsx";

const allFlashcards = await getCollection("flashcards");

const grouped: Record<string, { id: string; front: string; back: string; tags: string[]; difficulty: string }[]> = {};

for (const card of allFlashcards) {
  const primaryTag = card.data.tags[0] ?? "uncategorized";
  if (!grouped[primaryTag]) grouped[primaryTag] = [];
  grouped[primaryTag].push({
    id: card.id,
    front: card.data.front,
    back: card.data.back,
    tags: card.data.tags,
    difficulty: card.data.difficulty,
  });
}

const categories = Object.keys(grouped).sort();
const totalCount = allFlashcards.length;
---

<BaseLayout title="Flashcards">
  <h1 class="text-4xl font-extrabold mb-8 text-slate-900">Flashcard Decks</h1>
  <p class="text-slate-600 mb-8">
    Spaced repetition flashcards powered by FSRS. Click any card to flip, then rate your recall to
    schedule your next review. State is shared with the Review page.
  </p>

  <div class="mb-8 flex flex-wrap gap-2" id="category-nav">
    <button
      type="button"
      data-category="all"
      class="category-btn px-3 py-1.5 rounded-full text-xs font-medium transition-colors bg-[#0D9488] text-white"
    >
      All ({totalCount})
    </button>
    {categories.map((cat) => (
      <button
        type="button"
        data-category={cat}
        class="category-btn px-3 py-1.5 rounded-full text-xs font-medium transition-colors bg-slate-100 text-slate-600 hover:bg-slate-200"
      >
        {cat} ({grouped[cat].length})
      </button>
    ))}
  </div>

  {categories.map((cat) => (
    <div class="mb-8 category-section" data-category={cat}>
      <h2 class="text-2xl font-bold mb-4 text-slate-900 capitalize">
        {cat.replace(/-/g, " ")} <span class="text-base font-normal text-slate-500">({grouped[cat].length} cards)</span>
      </h2>
      <FlashcardDeck
        client:load
        cards={grouped[cat]}
        site="wiki"
        deckId="all-cards"
      />
    </div>
  ))}
</BaseLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>(".category-btn");
    const sections = document.querySelectorAll<HTMLElement>(".category-section");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const cat = btn.dataset.category;

        buttons.forEach((b) => {
          b.classList.remove("bg-[#0D9488]", "text-white");
          b.classList.add("bg-slate-100", "text-slate-600");
        });
        btn.classList.remove("bg-slate-100", "text-slate-600");
        btn.classList.add("bg-[#0D9488]", "text-white");

        sections.forEach((s) => {
          if (cat === "all" || s.dataset.category === cat) {
            s.style.display = "";
          } else {
            s.style.display = "none";
          }
        });
      });
    });
  });
</script>
