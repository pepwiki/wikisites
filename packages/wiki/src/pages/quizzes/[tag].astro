---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import QuizSession from "../../components/QuizSession.tsx";

export async function getStaticPaths() {
  const allQuizzes = await getCollection("quizzes");

  const tagMap = new Map<string, typeof allQuizzes>();
  for (const quiz of allQuizzes) {
    const tags: string[] = quiz.data.tags ?? [];
    for (const tag of tags) {
      if (!tagMap.has(tag)) tagMap.set(tag, []);
      tagMap.get(tag)!.push(quiz);
    }
  }

  return Array.from(tagMap.entries()).map(([tag, quizzes]) => ({
    params: { tag },
    props: {
      tag,
      questions: quizzes.map((q) => ({
        id: q.id,
        question: q.data.question,
        options: q.data.options,
        correctIndex: q.data.correctIndex,
        explanation: q.data.explanation,
        difficulty: q.data.difficulty,
        tags: q.data.tags,
      })),
    },
  }));
}

const { tag, questions } = Astro.props;
const topicName = tag.replace(/-/g, " ").replace(/\b\w/g, (c: string) => c.toUpperCase());

const quizJsonLd = {
  "@context": "https://schema.org",
  "@type": "Quiz",
  name: `${topicName} Quizzes`,
  description: `Test your knowledge of ${topicName} with interactive quizzes`,
  educationalLevel: "All levels",
};
---

<BaseLayout title={`${topicName} Quizzes | Wikipept`} description={`Test your knowledge of ${topicName} with interactive quizzes`}>
  <nav class="text-sm text-slate-500 dark:text-slate-400 mb-6">
    <a href="/quizzes" class="hover:text-[#0D9488] transition-colors">Quizzes</a>
    <span class="mx-2">/</span>
    <span class="text-slate-900 dark:text-slate-100">{topicName}</span>
  </nav>

  <h1 class="text-4xl font-extrabold mb-4 text-slate-900 dark:text-slate-100">
    {topicName} Quizzes
  </h1>
  <p class="text-slate-600 dark:text-slate-400 mb-8">
    Test your knowledge of {topicName.toLowerCase()} with {questions.length} interactive questions.
  </p>

  <QuizSession client:load questions={questions} title={`${topicName} Quizzes`} />

  <script is:inline type="application/ld+json" set:html={JSON.stringify(quizJsonLd)} />
</BaseLayout>
