---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Learn">
  <h1 class="text-4xl font-extrabold mb-8 text-slate-900">Learning Paths</h1>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-bold bg-[#0D9488] text-white px-3 py-1 rounded-full"
          >BEGINNER</span
        >
        <h2 class="text-xl font-bold text-slate-900">Fundamentals</h2>
      </div>
      <p class="text-slate-600 mb-4">
        Start here if you're new to biochemistry. Learn the basics of amino acids, peptide bonds,
        and protein structure.
      </p>
      <ul class="space-y-2 text-sm">
        <li class="flex items-center gap-2">
          <span
            class="w-5 h-5 bg-[#0D9488] text-white rounded-full flex items-center justify-center text-xs"
            >1</span
          >
          <a href="/learn/amino-acids" class="text-[#0D9488] hover:underline"
            >20 Standard Amino Acids</a
          >
        </li>
        <li class="flex items-center gap-2">
          <span
            class="w-5 h-5 bg-[#0D9488] text-white rounded-full flex items-center justify-center text-xs"
            >2</span
          >
          <a href="/learn/peptide-bonds" class="text-[#0D9488] hover:underline"
            >Peptide Bond Chemistry</a
          >
        </li>
        <li class="flex items-center gap-2">
          <span
            class="w-5 h-5 bg-[#0D9488] text-white rounded-full flex items-center justify-center text-xs"
            >3</span
          >
          <a href="/learn/structure" class="text-[#0D9488] hover:underline"
            >Protein Structure Levels</a
          >
        </li>
      </ul>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-bold bg-[#F97316] text-white px-3 py-1 rounded-full"
          >INTERMEDIATE</span
        >
        <h2 class="text-xl font-bold text-slate-900">Peptide Biology</h2>
      </div>
      <p class="text-slate-600 mb-4">
        Dive deeper into how peptides function in biological systems. Explore signaling, receptors,
        and pharmacology.
      </p>
      <ul class="space-y-2 text-sm">
        <li class="flex items-center gap-2">
          <span
            class="w-5 h-5 bg-[#F97316] text-white rounded-full flex items-center justify-center text-xs"
            >4</span
          >
          <a href="/learn/signaling" class="text-[#F97316] hover:underline">Peptide Signaling</a>
        </li>
        <li class="flex items-center gap-2">
          <span
            class="w-5 h-5 bg-[#F97316] text-white rounded-full flex items-center justify-center text-xs"
            >5</span
          >
          <a href="/learn/receptors" class="text-[#F97316] hover:underline">Receptor Binding</a>
        </li>
        <li class="flex items-center gap-2">
          <span
            class="w-5 h-5 bg-[#F97316] text-white rounded-full flex items-center justify-center text-xs"
            >6</span
          >
          <a href="/learn/pharmacology" class="text-[#F97316] hover:underline"
            >Therapeutic Peptides</a
          >
        </li>
      </ul>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-bold bg-purple-600 text-white px-3 py-1 rounded-full"
          >ADVANCED</span
        >
        <h2 class="text-xl font-bold text-slate-900">Synthesis & Design</h2>
      </div>
      <p class="text-slate-600 mb-4">
        Master peptide synthesis techniques and computational design. From SPPS to molecular
        dynamics.
      </p>
      <ul class="space-y-2 text-sm">
        <li class="flex items-center gap-2">
          <span
            class="w-5 h-5 bg-purple-600 text-white rounded-full flex items-center justify-center text-xs"
            >7</span
          >
          <a href="/learn/spps" class="text-purple-600 hover:underline">Solid-Phase Synthesis</a>
        </li>
        <li class="flex items-center gap-2">
          <span
            class="w-5 h-5 bg-purple-600 text-white rounded-full flex items-center justify-center text-xs"
            >8</span
          >
          <a href="/learn/purification" class="text-purple-600 hover:underline"
            >Purification Methods</a
          >
        </li>
        <li class="flex items-center gap-2">
          <span
            class="w-5 h-5 bg-purple-600 text-white rounded-full flex items-center justify-center text-xs"
            >9</span
          >
          <a href="/learn/computational" class="text-purple-600 hover:underline"
            >Computational Design</a
          >
        </li>
      </ul>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-bold bg-red-600 text-white px-3 py-1 rounded-full">EXPERT</span>
        <h2 class="text-xl font-bold text-slate-900">Clinical Applications</h2>
      </div>
      <p class="text-slate-600 mb-4">
        Advanced topics in peptide therapeutics, drug delivery, and clinical trials. For researchers
        and clinicians.
      </p>
      <ul class="space-y-2 text-sm">
        <li class="flex items-center gap-2">
          <span
            class="w-5 h-5 bg-red-600 text-white rounded-full flex items-center justify-center text-xs"
            >10</span
          >
          <a href="/learn/drug-delivery" class="text-red-600 hover:underline"
            >Drug Delivery Systems</a
          >
        </li>
        <li class="flex items-center gap-2">
          <span
            class="w-5 h-5 bg-red-600 text-white rounded-full flex items-center justify-center text-xs"
            >11</span
          >
          <a href="/learn/clinical-trials" class="text-red-600 hover:underline"
            >Clinical Trial Design</a
          >
        </li>
        <li class="flex items-center gap-2">
          <span
            class="w-5 h-5 bg-red-600 text-white rounded-full flex items-center justify-center text-xs"
            >12</span
          >
          <a href="/learn/regulatory" class="text-red-600 hover:underline">Regulatory Pathways</a>
        </li>
      </ul>
    </div>
  </div>
</BaseLayout>
