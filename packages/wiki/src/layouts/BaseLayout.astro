---
import "../styles/global.css";
import Toaster from "../components/ui/Toaster";
import MobileNav from "../components/MobileNav";
import CookieConsent from "../components/CookieConsent.tsx";
import PushNotifications from "../components/PushNotifications.tsx";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Collaborative wiki for learning oligopeptides -- quizzes, flashcards, community annotations",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      // Sync Starlight theme preference to data-theme attribute (render-blocking)
      (function () {
        var t = localStorage.getItem("starlight-theme");
        if (t === "dark" || t === "light") {
          document.documentElement.setAttribute("data-theme", t);
        } else if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          document.documentElement.setAttribute("data-theme", "dark");
        }
      })();
    </script>
    <script is:inline>
      // Theme analytics: track theme changes via MutationObserver
      (function () {
        var observer = new MutationObserver(function (mutations) {
          for (var i = 0; i < mutations.length; i++) {
            if (mutations[i].attributeName === "data-theme") {
              var theme = document.documentElement.getAttribute("data-theme");
              try {
                var events = JSON.parse(localStorage.getItem("wikisites:theme-analytics") || "[]");
                events.push({
                  theme: theme,
                  site: "wiki",
                  timestamp: Date.now(),
                  method: "starlight-toggle",
                });
                if (events.length > 100) events.splice(0, events.length - 100);
                localStorage.setItem("wikisites:theme-analytics", JSON.stringify(events));
              } catch (e) {}
            }
          }
        });
        observer.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["data-theme"],
        });
      })();
    </script>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#0D9488" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Wikipept`} />
    <meta property="og:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <title>{title} | Wikipept</title>
    <link rel="canonical" href={Astro.url.href} />
    <link rel="preconnect" href="https://static.cloudflareinsights.com" />
    <link rel="dns-prefetch" href="https://static.cloudflareinsights.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "WIKIPEPT_CF_ANALYTICS_TOKEN"}'></script>
    <link href="/_pagefind/pagefind-ui.css" rel="stylesheet" />
    <script src="/_pagefind/pagefind-ui.js" defer></script>
    <script is:inline>
      window.addEventListener("DOMContentLoaded", () => {
        if (typeof PagefindUI !== "undefined") {
          new PagefindUI({ element: "#search", showSubResults: true });
        }
      });
    </script>
  </head>
  <body class="bg-[#F8FAFC] dark:bg-slate-950 text-slate-900 dark:text-slate-100 font-sans">
    <Toaster client:only="solid-js" />
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-[#0D9488] focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:outline-none focus:ring-2 focus:ring-white"
    >
      Skip to content
    </a>
    <header
      class="border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 shadow-sm relative"
    >
      <nav
        class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between"
        aria-label="Main navigation"
      >
        <a href="/" class="text-2xl font-extrabold tracking-tight text-[#0D9488]">
          Wiki<span class="text-[#ea580c]">pept</span>
        </a>
        <div class="hidden lg:flex gap-6 text-sm font-medium">
          <a
            href="/learn"
            class="text-slate-600 dark:text-slate-400 hover:text-[#0D9488] focus:text-[#0D9488] focus:outline-none focus:ring-2 focus:ring-[#0D9488] focus:ring-offset-2 dark:focus:ring-offset-slate-900 rounded transition-colors"
            >Learn</a
          >
          <a
            href="/review"
            class="text-slate-600 dark:text-slate-400 hover:text-[#0D9488] focus:text-[0D9488] focus:outline-none focus:ring-2 focus:ring-[#0D9488] focus:ring-offset-2 dark:focus:ring-offset-slate-900 rounded transition-colors"
            >Review</a
          >
          <a
            href="/quizzes"
            class="text-slate-600 dark:text-slate-400 hover:text-[#0D9488] focus:text-[0D9488] focus:outline-none focus:ring-2 focus:ring-[#0D9488] focus:ring-offset-2 dark:focus:ring-offset-slate-900 rounded transition-colors"
            >Quizzes</a
          >
          <a
            href="/flashcards"
            class="text-slate-600 dark:text-slate-400 hover:text-[#0D9488] focus:text-[0D9488] focus:outline-none focus:ring-2 focus:ring-[#0D9488] focus:ring-offset-2 dark:focus:ring-offset-slate-900 rounded transition-colors"
            >Flashcards</a
          >
          <a
            href="/community"
            class="text-slate-600 dark:text-slate-400 hover:text-[#0D9488] focus:text-[0D9488] focus:outline-none focus:ring-2 focus:ring-[#0D9488] focus:ring-offset-2 dark:focus:ring-offset-slate-900 rounded transition-colors"
            >Community</a
          >
          <a
            href="/glossary"
            class="text-slate-600 dark:text-slate-400 hover:text-[0D9488] focus:text-[0D9488] focus:outline-none focus:ring-2 focus:ring-[#0D9488] focus:ring-offset-2 dark:focus:ring-offset-slate-900 rounded transition-colors"
            >Glossary</a
          >
        </div>
        <MobileNav client:load currentPath={Astro.url.pathname} />
      </nav>
    </header>
    <div id="search" class="hidden"></div>
    <main id="main-content" class="max-w-7xl mx-auto px-6 py-8" tabindex="-1">
      <slot />
    </main>
    <footer
      class="border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 mt-16"
      role="contentinfo"
    >
      <div
        class="max-w-7xl mx-auto px-6 py-8 text-sm text-slate-500 dark:text-slate-400 flex flex-col md:flex-row items-center justify-between gap-4"
      >
        <p>&copy; 2026 Wikipept. Community-driven oligopeptide learning platform.</p>
        <a href="/privacy" class="hover:text-[#0D9488] transition-colors">Privacy Policy</a>
      </div>
    </footer>
    <PushNotifications client:load />
    <CookieConsent client:load />
    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/sw.js").catch(() => {});
        });
      }
    </script>
    <script is:inline>
      // RUM: Track Core Web Vitals
      (function () {
        function storeMetric(m) {
          try {
            var metrics = JSON.parse(localStorage.getItem("wikisites:rum-metrics") || "[]");
            metrics.push(m);
            if (metrics.length > 200) metrics.splice(0, metrics.length - 200);
            localStorage.setItem("wikisites:rum-metrics", JSON.stringify(metrics));
          } catch (e) {}
        }
        function rating(n, v) {
          var t = { LCP: [2500, 4000], FID: [100, 300], CLS: [0.1, 0.25], TTFB: [800, 1800] };
          if (!t[n]) return "good";
          return v <= t[n][0] ? "good" : v <= t[n][1] ? "needs-improvement" : "poor";
        }
        try {
          new PerformanceObserver(function (list) {
            var e = list.getEntries();
            var last = e[e.length - 1];
            if (last)
              storeMetric({
                name: "LCP",
                value: Math.round(last.startTime),
                rating: rating("LCP", last.startTime),
                site: "wiki",
                ts: Date.now(),
              });
          }).observe({ type: "largest-contentful-paint", buffered: true });
        } catch (e) {}
        try {
          var cls = 0;
          new PerformanceObserver(function (list) {
            list.getEntries().forEach(function (entry) {
              if (!entry.hadRecentInput) cls += entry.value;
            });
          }).observe({ type: "layout-shift", buffered: true });
          document.addEventListener("visibilitychange", function () {
            if (document.visibilityState === "hidden")
              storeMetric({
                name: "CLS",
                value: Math.round(cls * 1000) / 1000,
                rating: rating("CLS", cls),
                site: "wiki",
                ts: Date.now(),
              });
          });
        } catch (e) {}
        try {
          var nav = performance.getEntriesByType("navigation")[0];
          if (nav) {
            var ttfb = Math.round(nav.responseStart - nav.requestStart);
            storeMetric({
              name: "TTFB",
              value: ttfb,
              rating: rating("TTFB", ttfb),
              site: "wiki",
              ts: Date.now(),
            });
          }
        } catch (e) {}
      })();
    </script>
    <script is:inline>
      // Theme feedback prompt (after 3 page views)
      (function () {
        var views = parseInt(localStorage.getItem("wiki:page-views") || "0", 10);
        localStorage.setItem("wiki:page-views", String(views + 1));
        var shown = localStorage.getItem("wikisites:feedback-shown");
        if (!shown && views >= 2) {
          // Show feedback prompt (simplified inline version)
          var modal = document.createElement("div");
          modal.className = "fixed inset-0 z-[9999] flex items-center justify-center bg-black/50";
          modal.innerHTML =
            '<div class="bg-white dark:bg-slate-800 rounded-xl p-6 max-w-sm mx-4 shadow-xl"><h3 class="text-lg font-bold text-slate-900 dark:text-slate-100 mb-2">How\'s the dark mode?</h3><p class="text-sm text-slate-600 dark:text-slate-400 mb-4">Help us improve.</p><div class="flex gap-2 mb-4" id="fb-stars">' +
            [1, 2, 3, 4, 5]
              .map(function (i) {
                return (
                  '<button class="fb-star text-2xl text-slate-300 hover:text-yellow-400" data-r="' +
                  i +
                  '">★</button>'
                );
              })
              .join("") +
            '</div><div class="flex gap-2 justify-end"><button id="fb-skip" class="px-4 py-2 text-sm text-slate-600 dark:text-slate-400">Skip</button><button id="fb-submit" class="px-4 py-2 text-sm bg-[#0D9488] text-white rounded-lg" disabled>Submit</button></div></div>';
          document.body.appendChild(modal);
          var sel = 0;
          modal.querySelectorAll(".fb-star").forEach(function (b) {
            b.addEventListener("click", function () {
              sel = parseInt(b.getAttribute("data-r"));
              modal.querySelectorAll(".fb-star").forEach(function (s, i) {
                s.classList.toggle("text-yellow-400", i < sel);
                s.classList.toggle("text-slate-300", i >= sel);
              });
              document.getElementById("fb-submit").disabled = false;
            });
          });
          document.getElementById("fb-submit").addEventListener("click", function () {
            try {
              var fbs = JSON.parse(localStorage.getItem("wikisites:theme-feedback") || "[]");
              fbs.push({
                rating: sel,
                theme: document.documentElement.getAttribute("data-theme"),
                ts: Date.now(),
              });
              localStorage.setItem("wikisites:theme-feedback", JSON.stringify(fbs));
            } catch (e) {}
            localStorage.setItem("wikisites:feedback-shown", "true");
            modal.remove();
          });
          document.getElementById("fb-skip").addEventListener("click", function () {
            localStorage.setItem("wikisites:feedback-shown", "true");
            modal.remove();
          });
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  :root {
    --color-teal: #0d9488;
    --color-coral: #f97316;
  }
  body {
    font-family: "Inter", system-ui, sans-serif;
  }
  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
  }
  /* Visible focus ring for keyboard navigation */
  :focus-visible {
    outline: 2px solid #0d9488;
    outline-offset: 2px;
    border-radius: 4px;
  }
  /* Pagefind UI overrides */
  :root {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: #0d9488;
    --pagefind-ui-text: #334155;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #e2e8f0;
    --pagefind-ui-tag: #f1f5f9;
  }
  [data-theme="dark"] {
    --pagefind-ui-text: #cbd5e1;
    --pagefind-ui-background: #1e293b;
    --pagefind-ui-border: #334155;
    --pagefind-ui-tag: #1e293b;
  }
</style>
