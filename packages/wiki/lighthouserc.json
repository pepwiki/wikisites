{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "resource-summary:document:size": ["error", { "maxNumericValue": 512000 }],
        "resource-summary:script:size": ["error", { "maxNumericValue": 204800 }],
        "resource-summary:stylesheet:size": ["error", { "maxNumericValue": 51200 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 1500 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "interactive": ["warn", { "maxNumericValue": 3500 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 300 }],
        "mainthread-work-breakdown": ["warn", { "maxNumericValue": 4000 }],
        "bootup-time": ["warn", { "maxNumericValue": 3000 }],
        "dom-size": ["warn", { "maxNumericValue": 1500 }],
        "uses-long-cache-ttl": ["warn", { "minScore": 0.7 }],
        "render-blocking-resources": ["warn", { "maxNumericValue": 500 }],
        "unused-javascript": ["warn", { "maxNumericValue": 50000 }]
      }
    },
    "upload": {
      "target": "lhci",
      "serverBaseUrl": "https://lhci.example.com"
    }
  }
}
