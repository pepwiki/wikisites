  "performance": {
    "lighthouse": { "perf": 90, "a11y": 95, "best-practices": 90, "seo": 95 },
    "core-web-vitals": {
      "lcp": { "p50": 1200, "p95": 2500, "unit": "ms" },
      "fid": { "p50": 50, "p95": 150, "unit": "ms" },
      "cls": { "p50": 0.05, "p95": 0.1 },
