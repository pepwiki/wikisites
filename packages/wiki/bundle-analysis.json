{
  "budgets": [
    { "name": "initial-js", "maximumWarning": "100KB", "maximumError": "150KB" },
    { "name": "initial-css", "maximumWarning": "30KB", "maximumError": "50KB" },
    { "name": "lazy-katex", "maximumWarning": "150KB", "maximumError": "200KB" },
    { "name": "lazy-force-graph", "maximumWarning": "50KB", "maximumError": "75KB" },
    { "name": "lazy-tiptap", "maximumWarning": "100KB", "maximumError": "150KB" }
