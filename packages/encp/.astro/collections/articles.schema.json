{
  "$ref": "#/definitions/articles",
  "definitions": {
    "articles": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 320
        },
        "status": {
          "type": "string",
          "enum": ["draft", "review", "published", "deprecated"],
          "default": "draft"
        },
        "author": {
          "type": "string",
          "minLength": 1
        },
        "pubDate": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "updatedDate": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "difficulty": {
          "type": "string",
          "enum": ["beginner", "intermediate", "advanced", "expert"],
          "default": "intermediate"
        },
        "relatedArticles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "citation": {
          "type": "object",
          "properties": {
            "doi": {
              "type": "string"
            },
            "pmid": {
              "type": "string"
            },
            "authors": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "journal": {
              "type": "string"
            },
            "year": {
              "type": "integer"
            }
          },
          "additionalProperties": false
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": ["title", "description", "author", "pubDate", "category"],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
