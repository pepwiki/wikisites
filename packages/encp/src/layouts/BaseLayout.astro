---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Comprehensive oligopeptide reference -- molecular structures, synthesis pathways, pharmacokinetics",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#0A1628" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Encyclopeptide`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="Encyclopeptide" />
    <meta property="og:image" content="https://encyclopeptide.com/og-default.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Encyclopeptide`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://encyclopeptide.com/og-default.svg" />
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Encyclopeptide",
        "url": "https://encyclopeptide.com",
        "description": "Academic reference for oligopeptide research"
      }
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Encyclopeptide</title>
    <link rel="canonical" href={Astro.url.href} />
    <link rel="preconnect" href="https://static.cloudflareinsights.com" />
    <link rel="dns-prefetch" href="https://static.cloudflareinsights.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "ENCYCLOPEPTIDE_CF_ANALYTICS_TOKEN"}'></script>
    <link href="/_pagefind/pagefind-ui.css" rel="stylesheet" />
    <script src="/_pagefind/pagefind-ui.js" defer></script>
    <script is:inline>
      // Theme sync: read preference and set data-theme before paint
      (function () {
        var t = localStorage.getItem("encp-theme") || "system";
        if (t === "dark") {
          document.documentElement.setAttribute("data-theme", "dark");
        } else if (t === "light") {
          document.documentElement.setAttribute("data-theme", "light");
        } else if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          document.documentElement.setAttribute("data-theme", "dark");
        }

        // Apply theme preset CSS custom properties
        var preset = localStorage.getItem("wikisites:theme-preset") || "light";
        var presets = {
          light: {
            bg: "#f8fafc",
            surface: "#ffffff",
            elevated: "#ffffff",
            text: "#1e293b",
            muted: "#64748b",
            border: "#e2e8f0",
            accent: "#0d9488",
          },
          dark: {
            bg: "#020617",
            surface: "#1e293b",
            elevated: "#0f172a",
            text: "#e2e8f0",
            muted: "#94a3b8",
            border: "#334155",
            accent: "#0d9488",
          },
          "high-contrast": {
            bg: "#000000",
            surface: "#1a1a1a",
            elevated: "#0d0d0d",
            text: "#ffffff",
            muted: "#cccccc",
            border: "#444444",
            accent: "#00ffcc",
          },
          solarized: {
            bg: "#002b36",
            surface: "#073642",
            elevated: "#002b36",
            text: "#839496",
            muted: "#586e75",
            border: "#073642",
            accent: "#2aa198",
          },
        };
        var p = presets[preset] || presets.light;
        var root = document.documentElement;
        root.style.setProperty("--theme-bg", p.bg);
        root.style.setProperty("--theme-surface", p.surface);
        root.style.setProperty("--theme-surface-elevated", p.elevated);
        root.style.setProperty("--theme-text", p.text);
        root.style.setProperty("--theme-text-muted", p.muted);
        root.style.setProperty("--theme-border", p.border);
        root.style.setProperty("--theme-accent", p.accent);
      })();
    </script>
    <script is:inline>
      window.addEventListener("DOMContentLoaded", () => {
        if (typeof PagefindUI !== "undefined") {
          new PagefindUI({ element: "#search", showSubResults: true });
        }
      });
    </script>
    <script src="/i18n-init.js" defer></script>
  </head>
  <body class="bg-white dark:bg-slate-950 text-slate-900 dark:text-slate-100 font-sans">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-[#C9A84C] dark:bg-[#d4b85c] focus:text-[#0A1628] dark:text-slate-100 focus:px-4 focus:py-2 focus:rounded-lg focus:outline-none focus:ring-2 focus:ring-white"
    >
      Skip to content
    </a>
    <header class="border-b border-slate-200 dark:border-slate-700 bg-[#0f172a] text-white">
      <nav
        class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between"
        aria-label="Main navigation"
      >
        <a href="/" class="text-2xl font-serif font-bold tracking-tight">
          <span class="text-[#C9A84C]">Encyclo</span>peptide
        </a>
        <div class="hidden md:flex gap-6 text-sm font-medium">
          <a
            href="/peptides"
            class="hover:text-[#C9A84C] focus:text-[#C9A84C] focus:outline-none focus:ring-2 focus:ring-[#C9A84C] focus:ring-offset-2 focus:ring-offset-[#0A1628] rounded transition-colors"
            >Peptides</a
          >
          <a
            href="/classification"
            class="hover:text-[#C9A84C] focus:text-[#C9A84C] focus:outline-none focus:ring-2 focus:ring-[#C9A84C] focus:ring-offset-2 focus:ring-offset-[#0A1628] rounded transition-colors"
            >Classification</a
          >
          <a
            href="/synthesis"
            class="hover:text-[#C9A84C] focus:text-[#C9A84C] focus:outline-none focus:ring-2 focus:ring-[#C9A84C] focus:ring-offset-2 focus:ring-offset-[#0A1628] rounded transition-colors"
            >Synthesis</a
          >
          <a
            href="/pharmacology"
            class="hover:text-[#C9A84C] focus:text-[#C9A84C] focus:outline-none focus:ring-2 focus:ring-[#C9A84C] focus:ring-offset-2 focus:ring-offset-[#0A1628] rounded transition-colors"
            >Pharmacology</a
          >
          <a
            href="/glossary"
            class="hover:text-[#C9A84C] focus:text-[#C9A84C] focus:outline-none focus:ring-2 focus:ring-[#C9A84C] focus:ring-offset-2 focus:ring-offset-[#0A1628] rounded transition-colors"
            >Glossary</a
          >
        </div>
        <button
          id="theme-toggle"
          type="button"
          class="p-2 rounded-lg text-white hover:bg-white dark:bg-slate-900/10 focus:outline-none focus:ring-2 focus:ring-[#C9A84C] transition-colors"
          aria-label="Toggle dark mode"
        >
          <svg
            id="icon-sun"
            class="w-5 h-5 hidden"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
            ></path>
          </svg>
          <svg
            id="icon-moon"
            class="w-5 h-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
            ></path>
          </svg>
          <svg
            id="icon-system"
            class="w-5 h-5 hidden"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path>
          </svg>
        </button>
      </nav>
    </header>
    <div id="search" class="hidden"></div>
    <main id="main-content" class="max-w-7xl mx-auto px-6 py-8" tabindex="-1">
      <slot />
    </main>
    <footer
      class="border-t border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 mt-16"
      role="contentinfo"
    >
      <div class="max-w-7xl mx-auto px-6 py-8 text-sm text-slate-500 dark:text-slate-400">
        <p>&copy; 2026 Encyclopeptide. Academic reference for oligopeptide research.</p>
      </div>
    </footer>
    <script is:inline>
      // Theme toggle logic: light -> dark -> system -> light
      (function () {
        var toggle = document.getElementById("theme-toggle");
        var sun = document.getElementById("icon-sun");
        var moon = document.getElementById("icon-moon");
        var system = document.getElementById("icon-system");
        var html = document.documentElement;

        function getTheme() {
          return localStorage.getItem("encp-theme") || "system";
        }

        function applyTheme(theme) {
          if (theme === "system") {
            var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
            html.setAttribute("data-theme", prefersDark ? "dark" : "light");
          } else {
            html.setAttribute("data-theme", theme);
          }
        }

        function updateIcons() {
          var theme = getTheme();
          sun.classList.toggle("hidden", theme !== "dark");
          moon.classList.toggle("hidden", theme !== "light");
          system.classList.toggle("hidden", theme !== "system");
        }

        applyTheme(getTheme());
        updateIcons();

        // Listen for system theme changes
        window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", function () {
          if (getTheme() === "system") {
            applyTheme("system");
          }
        });

        toggle.addEventListener("click", function () {
          var current = getTheme();
          var next = current === "light" ? "dark" : current === "dark" ? "system" : "light";
          localStorage.setItem("encp-theme", next);
          applyTheme(next);
          updateIcons();
          trackThemeChange("encp", next, "toggle");
        });
      })();

      // Theme analytics
      function trackThemeChange(site, theme, method) {
        try {
          var events = JSON.parse(localStorage.getItem("wikisites:theme-analytics") || "[]");
          events.push({ theme: theme, site: site, timestamp: Date.now(), method: method });
          if (events.length > 100) events.splice(0, events.length - 100);
          localStorage.setItem("wikisites:theme-analytics", JSON.stringify(events));
        } catch (e) {}
      }
    </script>
    <script is:inline>
      // RUM: Track Core Web Vitals for ENCP
      (function () {
        function storeMetric(m) {
          try {
            var metrics = JSON.parse(localStorage.getItem("wikisites:rum-metrics") || "[]");
            metrics.push(m);
            if (metrics.length > 200) metrics.splice(0, metrics.length - 200);
            localStorage.setItem("wikisites:rum-metrics", JSON.stringify(metrics));
          } catch (e) {}
        }
        function rating(n, v) {
          var t = { LCP: [2500, 4000], FID: [100, 300], CLS: [0.1, 0.25], TTFB: [800, 1800] };
          if (!t[n]) return "good";
          return v <= t[n][0] ? "good" : v <= t[n][1] ? "needs-improvement" : "poor";
        }
        try {
          new PerformanceObserver(function (list) {
            var e = list.getEntries();
            var last = e[e.length - 1];
            if (last)
              storeMetric({
                name: "LCP",
                value: Math.round(last.startTime),
                rating: rating("LCP", last.startTime),
                site: "encp",
                ts: Date.now(),
              });
          }).observe({ type: "largest-contentful-paint", buffered: true });
        } catch (e) {}
        try {
          var nav = performance.getEntriesByType("navigation")[0];
          if (nav) {
            var ttfb = Math.round(nav.responseStart - nav.requestStart);
            storeMetric({
              name: "TTFB",
              value: ttfb,
              rating: rating("TTFB", ttfb),
              site: "encp",
              ts: Date.now(),
            });
          }
        } catch (e) {}
      })();
    </script>
  </body>
</html>

<style is:global>
  :root {
    --color-navy: #0a1628;
    --color-gold: #c9a84c;
    --color-slate: #64748b;
  }
  body {
    font-family: "Inter", system-ui, sans-serif;
  }
  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: "Playfair Display", Georgia, serif;
  }
  code,
  pre {
    font-family: "JetBrains Mono", monospace;
  }
  :focus-visible {
    outline: 2px solid #c9a84c;
    outline-offset: 2px;
    border-radius: 4px;
  }
  /* Pagefind UI overrides */
  :root {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: #0a1628;
    --pagefind-ui-text: #334155;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #e2e8f0;
    --pagefind-ui-tag: #f1f5f9;
  }
  [data-theme="dark"] {
    --pagefind-ui-text: #cbd5e1;
    --pagefind-ui-background: #1e293b;
    --pagefind-ui-border: #334155;
    --pagefind-ui-tag: #1e293b;
  }
  /* Theme transitions */
  body {
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }
</style>
