---
/**
 * ThemePresetSelector - A dropdown for selecting theme presets.
 * Usage: <ThemePresetSelector />
 */

interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div class={`relative ${className}`}>
  <button
    id="preset-toggle"
    type="button"
    class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-[#C9A84C] transition-colors"
    aria-label="Select theme preset"
    aria-haspopup="true"
    aria-expanded="false"
  >
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"
      ></path>
    </svg>
    <span id="preset-label">Theme</span>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
    </svg>
  </button>

  <div
    id="preset-menu"
    class="hidden absolute right-0 mt-2 w-48 rounded-lg shadow-lg bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 z-50"
    role="menu"
  >
    <div class="py-1">
      <button
        class="preset-option w-full text-left px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700"
        data-preset="light"
        role="menuitem"
      >
        <span class="inline-block w-3 h-3 rounded-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-600 mr-2"
        ></span>
        Light
      </button>
      <button
        class="preset-option w-full text-left px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700"
        data-preset="dark"
        role="menuitem"
      >
        <span class="inline-block w-3 h-3 rounded-full bg-slate-900 border border-slate-600 mr-2"
        ></span>
        Dark
      </button>
      <button
        class="preset-option w-full text-left px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700"
        data-preset="high-contrast"
        role="menuitem"
      >
        <span class="inline-block w-3 h-3 rounded-full bg-black border border-white mr-2"></span>
        High Contrast
      </button>
      <button
        class="preset-option w-full text-left px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700"
        data-preset="solarized"
        role="menuitem"
      >
        <span class="inline-block w-3 h-3 rounded-full bg-[#002b36] border border-[#2aa198] mr-2"
        ></span>
        Solarized
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var toggle = document.getElementById("preset-toggle");
    var menu = document.getElementById("preset-menu");
    var label = document.getElementById("preset-label");
    var options = document.querySelectorAll(".preset-option");

    var presetNames = {
      light: "Light",
      dark: "Dark",
      "high-contrast": "High Contrast",
      solarized: "Solarized",
    };

    var current = localStorage.getItem("wikisites:theme-preset") || "light";
    label.textContent = presetNames[current] || "Theme";

    toggle.addEventListener("click", function () {
      var isExpanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", !isExpanded);
      menu.classList.toggle("hidden");
    });

    options.forEach(function (opt) {
      opt.addEventListener("click", function () {
        var preset = opt.getAttribute("data-preset");
        localStorage.setItem("wikisites:theme-preset", preset);
        label.textContent = presetNames[preset] || "Theme";
        menu.classList.add("hidden");
        toggle.setAttribute("aria-expanded", "false");
        // Reload to apply preset
        window.location.reload();
      });
    });

    // Close on outside click
    document.addEventListener("click", function (e) {
      if (!toggle.contains(e.target) && !menu.contains(e.target)) {
        menu.classList.add("hidden");
        toggle.setAttribute("aria-expanded", "false");
      }
    });
  })();
</script>
