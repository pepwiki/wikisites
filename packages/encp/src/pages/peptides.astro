---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Peptides Database">
  <h1 class="text-4xl font-bold mb-8 text-[#0A1628]">Oligopeptide Database</h1>

  <div class="mb-6">
    <input
      type="text"
      placeholder="Search by name, sequence, or function..."
      class="w-full max-w-xl px-5 py-3 border-2 border-slate-200 rounded-lg text-sm focus:border-[#C9A84C] focus:outline-none transition-colors"
    />
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <a
      href="/peptides/glutathione"
      class="block p-5 border border-slate-200 rounded-xl hover:shadow-lg transition-shadow"
    >
      <div class="flex items-start justify-between">
        <div>
          <h3 class="font-semibold text-[#0A1628]">Glutathione</h3>
          <p class="text-sm text-slate-500 mt-1">γ-L-Glutamyl-L-cysteinylglycine</p>
        </div>
        <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded">Tripeptide</span>
      </div>
      <div class="mt-3 flex gap-4 text-xs text-slate-400">
        <span>MW 307.32</span>
        <span>Charge −1</span>
        <span>pI 5.93</span>
      </div>
      <p class="text-sm text-slate-600 mt-2">
        Master antioxidant. Essential for cellular redox balance and Phase II detoxification.
      </p>
    </a>

    <a
      href="/peptides/oxytocin"
      class="block p-5 border border-slate-200 rounded-xl hover:shadow-lg transition-shadow"
    >
      <div class="flex items-start justify-between">
        <div>
          <h3 class="font-semibold text-[#0A1628]">Oxytocin</h3>
          <p class="text-sm text-slate-500 mt-1">Cys-Tyr-Ile-Gln-Asn-Cys-Pro-Leu-Gly-NH₂</p>
        </div>
        <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded">Nonapeptide</span>
      </div>
      <div class="mt-3 flex gap-4 text-xs text-slate-400">
        <span>MW 1007.19</span>
        <span>Charge +1</span>
        <span>pI 7.7</span>
      </div>
      <p class="text-sm text-slate-600 mt-2">
        Neuropeptide hormone. Regulates social bonding, uterine contraction, and milk ejection.
      </p>
    </a>

    <a
      href="/peptides/enkephalin"
      class="block p-5 border border-slate-200 rounded-xl hover:shadow-lg transition-shadow"
    >
      <div class="flex items-start justify-between">
        <div>
          <h3 class="font-semibold text-[#0A1628]">Leucine-Enkephalin</h3>
          <p class="text-sm text-slate-500 mt-1">Tyr-Gly-Gly-Phe-Leu</p>
        </div>
        <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded">Pentapeptide</span>
      </div>
      <div class="mt-3 flex gap-4 text-xs text-slate-400">
        <span>MW 555.62</span>
        <span>Charge 0</span>
        <span>pI 5.6</span>
      </div>
      <p class="text-sm text-slate-600 mt-2">
        Endogenous opioid peptide. Binds μ and δ opioid receptors. Analgesic properties.
      </p>
    </a>

    <a
      href="/peptides/bradykinin"
      class="block p-5 border border-slate-200 rounded-xl hover:shadow-lg transition-shadow"
    >
      <div class="flex items-start justify-between">
        <div>
          <h3 class="font-semibold text-[#0A1628]">Bradykinin</h3>
          <p class="text-sm text-slate-500 mt-1">Arg-Pro-Pro-Gly-Phe-Ser-Pro-Phe-Arg</p>
        </div>
        <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded">Nonapeptide</span>
      </div>
      <div class="mt-3 flex gap-4 text-xs text-slate-400">
        <span>MW 1060.2</span>
        <span>Charge +2</span>
        <span>pI 12.0</span>
      </div>
      <p class="text-sm text-slate-600 mt-2">
        Vasodilator. Involved in inflammation, pain signaling, and blood pressure regulation.
      </p>
    </a>
  </div>
</BaseLayout>
