---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const siteUrl = "https://encyclopeptide.com";
const canonicalUrl = `${siteUrl}/articles/${article.id}`;
const pubDateStr = article.data.pubDate.toISOString().split("T")[0];
const modDateStr = article.data.updatedDate
  ? article.data.updatedDate.toISOString().split("T")[0]
  : pubDateStr;

const scholarlyArticleJsonLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "ScholarlyArticle",
  headline: article.data.title,
  description: article.data.description,
  author: { "@type": "Organization", name: article.data.author },
  datePublished: pubDateStr,
  dateModified: modDateStr,
  publisher: {
    "@type": "Organization",
    name: "Encyclopeptide",
    logo: { "@type": "ImageObject", url: `${siteUrl}/og-default.svg` },
  },
  mainEntityOfPage: canonicalUrl,
  image: `${siteUrl}/og-default.svg`,
};

if (article.data.citation?.doi) {
  scholarlyArticleJsonLd.citation = {
    "@type": "ScholarlyArticle",
    name: article.data.title,
    url: `https://doi.org/${article.data.citation.doi}`,
  };
}

const chemicalSubstanceJsonLd: Record<string, unknown> | null = (() => {
  const body = article.body;
  const formulaMatch = body.match(/\*\*Chemical Formula\*\*\s*\|\s*([^\s|]+)/i);
  const mwMatch = body.match(/\*\*Molecular Weight\*\*\s*\|\s*([^\s|]+)/i);
  const seqMatch = body.match(/\*\*Sequence\*\*\s*\|\s*`?([^`|]+)`?/i);

  if (!formulaMatch && !mwMatch) return null;

  const substance: Record<string, unknown> = {
    "@context": "https://schema.org",
    "@type": "ChemicalSubstance",
    name: article.data.title,
    description: article.data.description,
  };
  if (formulaMatch) substance.molecularFormula = formulaMatch[1].trim();
  if (mwMatch) substance.molecularWeight = mwMatch[1].trim();
  if (seqMatch) substance.smiles = seqMatch[1].trim();

  return substance;
})();

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: article.data.category, item: `${siteUrl}/` },
    { "@type": "ListItem", position: 3, name: article.data.title },
  ],
};

// Extract headings for Table of Contents
const headingRegex = /^#{2,3}\s+(.+)$/gm;
const headings = [];
let match;
while ((match = headingRegex.exec(article.body)) !== null) {
  const level = match[0].startsWith("### ") ? 3 : 2;
  const text = match[1].trim();
  const id = text
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");
  headings.push({ level, text, id });
}
---

<BaseLayout title={article.data.title} description={article.data.description}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(scholarlyArticleJsonLd)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  {chemicalSubstanceJsonLd && (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(chemicalSubstanceJsonLd)} />
  )}
  <article class="max-w-3xl">
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-bold bg-[#0A1628] text-white px-3 py-1 rounded-full uppercase">
          {article.data.category}
        </span>
        <span
          class="text-xs font-bold bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 px-3 py-1 rounded-full uppercase"
        >
          {article.data.difficulty}
        </span>
      </div>
      <h1 class="text-4xl font-bold text-[#0A1628] dark:text-slate-100 mb-4">
        {article.data.title}
      </h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 mb-4">{article.data.description}</p>
      <div class="flex items-center gap-4 text-sm text-slate-500 dark:text-slate-400">
        <span>By {article.data.author}</span>
        <time datetime={article.data.pubDate.toISOString()}>
          {
            article.data.pubDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </time>
        <span class="text-slate-400 dark:text-slate-500">|</span>
        <span>{Math.ceil(article.body.split(/\s+/).length / 200)} min read</span>
        {
          article.data.updatedDate && (
            <>
              <span class="text-slate-400 dark:text-slate-500">|</span>
              <span>
                Updated{" "}
                {article.data.updatedDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </span>
            </>
          )
        }
      </div>
      {
        article.data.tags.length > 0 && (
          <div class="flex gap-2 mt-4">
            {article.data.tags.map((tag) => (
              <span class="text-xs bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 px-2 py-1 rounded">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </header>

    {
      headings.length > 0 && (
        <nav class="mb-8 p-4 bg-slate-50 dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800">
          <h3 class="text-sm font-semibold text-[#0A1628] dark:text-slate-100 mb-3">
            Table of Contents
          </h3>
          <ul class="space-y-1">
            {headings.map((h) => (
              <li class={h.level === 3 ? "ml-4" : ""}>
                <a
                  href={`#${h.id}`}
                  class="text-sm text-slate-600 dark:text-slate-400 hover:text-[#C9A84C] transition-colors"
                >
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }

    <div class="prose prose-slate max-w-none">
      <Content />
    </div>

    {
      article.data.citation && (
        <footer class="mt-12 p-6 bg-slate-50 dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800">
          <h3 class="font-semibold text-[#0A1628] dark:text-slate-100 mb-2">Citation</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            {article.data.citation.authors.join(", ")} ({article.data.citation.year}).
            {article.data.citation.journal && ` ${article.data.citation.journal}.`}
            {article.data.citation.doi && (
              <a
                href={`https://doi.org/${article.data.citation.doi}`}
                class="text-[#C9A84C] hover:underline"
                target="_blank"
                rel="noopener noreferrer"
              >
                DOI: {article.data.citation.doi}
              </a>
            )}
          </p>
        </footer>
      )
    }

    {
      article.data.relatedArticles.length > 0 && (
        <nav class="mt-8 pt-8 border-t border-slate-200 dark:border-slate-800">
          <h3 class="font-semibold text-[#0A1628] dark:text-slate-100 mb-3">Related Articles</h3>
          <div class="flex gap-3">
            {article.data.relatedArticles.map((slug) => (
              <a
                href={`/articles/${slug}`}
                class="text-sm text-[#C9A84C] hover:underline border border-[#C9A84C] px-3 py-1 rounded-full"
              >
                {slug}
              </a>
            ))}
          </div>
        </nav>
      )
    }

    <div class="mt-8 p-4 bg-[#0D9488]/5 border border-[#0D9488]/20 rounded-xl">
      <h3 class="font-semibold text-[#0f766e] mb-2">Test Your Knowledge</h3>
      <p class="text-sm text-slate-600 dark:text-slate-400 mb-3">
        Reinforce what you learned about {article.data.title} with interactive quizzes on Wikipept.
      </p>
      <a
        href="https://wikipept.com/quizzes"
        class="inline-block px-4 py-2 bg-[#0D9488] text-white rounded-lg text-sm font-medium hover:bg-[#0D9488]/90 transition-colors"
        target="_blank"
        rel="noopener noreferrer"
      >
        Take a Quiz on Wikipept
      </a>
    </div>
  </article>
</BaseLayout>
