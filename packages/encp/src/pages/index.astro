---
import BaseLayout from "../layouts/BaseLayout.astro";
import MWCalculator from "../components/MWCalculator.tsx";
---

<BaseLayout title="Home">
  <section class="py-16 text-center" aria-labelledby="hero-heading">
    <h1 id="hero-heading" class="text-5xl font-bold mb-6 text-[#0A1628] dark:text-slate-100">
      The Oligopeptide <span class="text-[#C9A84C]">Reference</span>
    </h1>
    <p class="text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto mb-8">
      Comprehensive, peer-reviewed reference for oligopeptide research. Molecular structures,
      synthesis pathways, pharmacokinetics, and biological activity.
    </p>
    <div class="flex gap-4 justify-center">
      <a
        href="/peptides"
        class="px-6 py-3 bg-[#0A1628] text-white rounded-lg font-medium hover:bg-[#0A1628]/90 transition-colors focus:outline-none focus:ring-2 focus:ring-[#C9A84C] focus:ring-offset-2"
      >
        Browse Peptides
      </a>
      <a
        href="/classification"
        class="px-6 py-3 border-2 border-[#0A1628] dark:border-slate-700 text-[#0A1628] dark:text-slate-100 rounded-lg font-medium hover:bg-[#0A1628] hover:text-white transition-colors focus:outline-none focus:ring-2 focus:ring-[#0A1628] focus:ring-offset-2"
      >
        Classification System
      </a>
    </div>
  </section>

  <section class="py-12" aria-label="Molecular Weight Calculator">
    <MWCalculator client:load />
  </section>

  <section class="grid grid-cols-1 md:grid-cols-3 gap-8 py-12" aria-labelledby="features-heading">
    <h2 id="features-heading" class="sr-only">Platform Features</h2>
    <article
      class="p-6 border border-slate-200 dark:border-slate-800 rounded-xl hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300"
    >
      <h3 class="text-lg font-semibold mb-3 text-[#0A1628] dark:text-slate-100">
        Molecular Database
      </h3>
      <p class="text-slate-600 dark:text-slate-400">
        Detailed monographs for 500+ oligopeptides with molecular weight, charge state, isoelectric
        point, and structural data.
      </p>
    </article>
    <article
      class="p-6 border border-slate-200 dark:border-slate-800 rounded-xl hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300"
    >
      <h3 class="text-lg font-semibold mb-3 text-[#0A1628] dark:text-slate-100">
        Synthesis Pathways
      </h3>
      <p class="text-slate-600 dark:text-slate-400">
        Step-by-step synthesis routes for solid-phase, liquid-phase, and recombinant production
        methods.
      </p>
    </article>
    <article
      class="p-6 border border-slate-200 dark:border-slate-800 rounded-xl hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300"
    >
      <h3 class="text-lg font-semibold mb-3 text-[#0A1628] dark:text-slate-100">
        Pharmacology Data
      </h3>
      <p class="text-slate-600 dark:text-slate-400">
        Receptor binding affinity, ADMET parameters, half-life, bioavailability, and therapeutic
        applications.
      </p>
    </article>
  </section>

  <section
    class="py-12 border-t border-slate-200 dark:border-slate-800"
    aria-labelledby="featured-heading"
  >
    <h2 id="featured-heading" class="text-3xl font-bold mb-8 text-[#0A1628] dark:text-slate-100">
      Featured Oligopeptides
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <a
        href="/articles/glutathione"
        class="block p-5 border border-slate-200 dark:border-slate-800 rounded-xl hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-[#C9A84C] focus:ring-offset-2"
      >
        <h3 class="font-semibold text-[#0A1628] dark:text-slate-100">Glutathione</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
          Glu-Cys-Gly -- Tripeptide -- Antioxidant
        </p>
        <span
          class="inline-block mt-2 text-xs bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 px-2 py-1 rounded"
        >
          MW 307.32
        </span>
      </a>
      <a
        href="/articles/oxytocin"
        class="block p-5 border border-slate-200 dark:border-slate-800 rounded-xl hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-[#C9A84C] focus:ring-offset-2"
      >
        <h3 class="font-semibold text-[#0A1628] dark:text-slate-100">Oxytocin</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
          Nonapeptide -- Neuropeptide -- Hormone
        </p>
        <span
          class="inline-block mt-2 text-xs bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 px-2 py-1 rounded"
        >
          MW 1007.19
        </span>
      </a>
      <a
        href="/articles/insulin-a-chain"
        class="block p-5 border border-slate-200 dark:border-slate-800 rounded-xl hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-[#C9A84C] focus:ring-offset-2"
      >
        <h3 class="font-semibold text-[#0A1628] dark:text-slate-100">Insulin A-Chain</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
          21 aa -- Peptide Hormone -- Metabolic
        </p>
        <span
          class="inline-block mt-2 text-xs bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 px-2 py-1 rounded"
        >
          MW 2383.88
        </span>
      </a>
      <a
        href="/articles/leucine-enkephalin"
        class="block p-5 border border-slate-200 dark:border-slate-800 rounded-xl hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-[#C9A84C] focus:ring-offset-2"
      >
        <h3 class="font-semibold text-[#0A1628] dark:text-slate-100">Leucine-Enkephalin</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
          Tyr-Gly-Gly-Phe-Leu -- Pentapeptide -- Analgesic
        </p>
        <span
          class="inline-block mt-2 text-xs bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 px-2 py-1 rounded"
        >
          MW 555.62
        </span>
      </a>
    </div>
  </section>
</BaseLayout>
