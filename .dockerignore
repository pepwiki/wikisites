# =============================================================================
# Wikisites — Docker Ignore
# Keep Docker context lean and secure
# =============================================================================

# Dependencies (rebuilt inside container)
node_modules

# Build output (rebuilt inside container)
dist
.cache

# Version control
.git
.gitignore

# Development artifacts
coverage
reports
.reports
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Environment files (secrets must not be in image)
.env
.env.*
!.env.example

# IDE and editor files
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# Nix
result
result-*

# Documentation (not needed in image)
*.md
!package.json
LICENSE

# Test artifacts
test-results
playwright-report
blob-report

# CI/CD
.github
.gitlab-ci.yml

# Docker (prevent recursive builds)
Dockerfile
docker-compose*.yml
.dockerignore
